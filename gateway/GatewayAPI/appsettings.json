{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*",

  "ReverseProxy": {
    "Routes": {
      "teacherRoute": {
        "ClusterId": "teacherCluster",
        "Match": { "Path": "/teachers/{**catch-all}" },
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed",
        "Transforms": [ { "PathRemovePrefix": "/teachers" } ]
      },
      "studentRoute": {
        "ClusterId": "studentCluster",
        "Match": { "Path": "/students/{**catch-all}" },
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed",
        "Transforms": [ { "PathRemovePrefix": "/students" } ]
      },
      "courseRoute": {
        "ClusterId": "courseCluster",
        "Match": { "Path": "/courses/{**catch-all}" },
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed",
        "Transforms": [ { "PathRemovePrefix": "/courses" } ]
      },
      "chatRoute": {
        "ClusterId": "chatCluster",
        "Match": { "Path": "/chat/{**catch-all}" },
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed",
        "Transforms": [ { "PathRemovePrefix": "/chat" } ]
      },

      "authRoute": {
        "ClusterId": "authCluster",
        "Match": { "Path": "/auth/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ]
      }
    },

    "Clusters": {
      "teacherCluster": {
        "Destinations": {
          "d1": { "Address": "https://localhost:5001/" }
        }
      },

      "studentCluster": {
        "Destinations": {
          "d1": { "Address": "https://localhost:5003/" }
        }
      },

      "courseCluster": {
        "Destinations": {
          "d1": { "Address": "https://localhost:5004/" }
        }
      },

      "chatCluster": {
        "Destinations": {
          "d1": { "Address": "https://localhost:5005/" }
        }
      },

      "authCluster": {
        "Destinations": {
          "d1": { "Address": "https://localhost:5002/" }
        }
      }
    }
  }
}

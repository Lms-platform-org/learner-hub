@{
    ViewData["Title"] = "The Horizon";
}

<div class="row mb-5">
    <div class="col-lg-8">
        <span class="badge-academic mb-3 d-inline-block">Institutional Portfolio</span>
        <h1 class="display-font text-white" style="font-size: 4.5rem; line-height: 0.9; margin-bottom: 2rem;">
            Discover Top <span class="text-gradient">Courses</span>
        </h1>
        <p class="text-muted lead mb-5" style="max-width: 600px; font-size: 1.25rem;">
            Initialize your learning journey via our high-performance REST API. Secure, scalable, and academically rigorous.
        </p>
        <div class="d-flex gap-4">
            <a href="http://localhost:5062/swagger" class="btn-premium">
                <i class="fa-solid fa-code me-2"></i> API Documentation
            </a>
            <button class="btn-outline-premium" onclick="openCreateModal()">
                <i class="fa-solid fa-plus-circle me-2"></i> Create Module
            </button>
        </div>
    </div>
</div>

<div class="glass-panel p-5 mb-5 border-opacity-10">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h3 class="display-font text-white mb-0">Active Academic Modules</h3>
        <div class="d-flex gap-2">
            <div id="status-dot" class="bg-success rounded-circle" style="width: 10px; height: 10px; margin-top: 7px;"></div>
            <span class="text-muted small fw-bold text-uppercase">API Live Connection</span>
        </div>
    </div>

    <div id="loading" class="text-center py-5">
        <div class="spinner-border text-success" role="status" style="width: 3rem; height: 3rem; border-width: 0.25rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-4 text-muted letter-spacing-2 small">Syncing Repository Data...</p>
    </div>

    <div id="course-container" class="row g-5" style="display: none;">
        <!-- Data populated via Javascript -->
    </div>
</div>

<!-- Modal for Create/Edit -->
<div class="modal fade" id="courseModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content glass-panel border-0 p-4">
      <div class="modal-header border-0">
        <h4 class="modal-title display-font text-white" id="modalTitle">Course Configuration</h4>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="courseForm">
            <input type="hidden" id="courseId" />
            <div class="row g-4">
                <div class="col-md-12">
                    <label class="form-label text-muted small fw-bold text-uppercase mb-2">Module Title</label>
                    <input type="text" class="form-control border-0 text-white" id="courseTitle" required 
                           style="background: rgba(255,255,255,0.05); padding: 1.2rem; border-radius: 12px;" 
                           placeholder="Enter high-level title...">
                </div>
                <div class="col-md-12">
                    <label class="form-label text-muted small fw-bold text-uppercase mb-2">Academic Description</label>
                    <textarea class="form-control border-0 text-white" id="courseDesc" rows="5" required 
                              style="background: rgba(255,255,255,0.05); padding: 1.2rem; border-radius: 12px;" 
                              placeholder="Module learning objectives..."></textarea>
                </div>
            </div>
            <div class="text-end mt-5 pt-4 border-top border-secondary border-opacity-10">
                <button type="button" class="btn btn-link text-muted text-decoration-none me-4" data-bs-dismiss="modal">Discard</button>
                <button type="submit" class="btn-premium px-5">Commit Changes</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        const API_URL = window.location.protocol === 'https:' 
            ? 'https://localhost:7081/api/CoursesApi' 
            : 'http://localhost:5062/api/CoursesApi';
        let courseModal;

        document.addEventListener('DOMContentLoaded', () => {
            courseModal = new bootstrap.Modal(document.getElementById('courseModal'));
            loadCourses();

            document.getElementById('courseForm').addEventListener('submit', async function(e) {
                e.preventDefault();
                await saveCourse();
            });
        });

        async function loadCourses() {
            document.getElementById('loading').style.display = 'block';
            document.getElementById('course-container').style.display = 'none';

            try {
                const response = await fetch(API_URL);
                const courses = await response.json();
                renderCourses(courses);
            } catch (error) {
                console.error('Error fetching courses:', error);
                document.getElementById('course-container').innerHTML = 
                    `<div class="col-12 text-center py-5 text-danger">REST API Connection Lost. Check console for error trace.</div>`;
            } finally {
                document.getElementById('loading').style.display = 'none';
                document.getElementById('course-container').style.display = 'flex';
            }
        }

        function renderCourses(courses) {
            const container = document.getElementById('course-container');
            container.innerHTML = '';

            courses.forEach(course => {
                const card = `
                    <div class="col-md-6">
                        <div class="premium-card h-100 d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <span class="badge-academic">Module v1.0</span>
                                <div class="dropdown">
                                    <button class="btn btn-link text-muted p-0" data-bs-toggle="dropdown">
                                        <i class="fa-solid fa-ellipsis-v"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end border-0 shadow-lg">
                                        <li><a class="dropdown-item py-2" href="javascript:void(0)" onclick="openEditModal(${course.id}, '${course.title.replace(/'/g, "\\'")}', '${course.description.replace(/'/g, "\\'")}')"><i class="fa-solid fa-edit me-2 small"></i> Edit Specs</a></li>
                                    </ul>
                                </div>
                            </div>
                            <h4 class="display-font text-white mb-3" style="font-size: 1.75rem;">${course.title}</h4>
                            <p class="text-muted small flex-grow-1" style="line-height: 1.8; opacity: 0.8;">${course.description}</p>
                            
                            <div class="mt-4 pt-4 border-top border-secondary border-opacity-10 d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="bg-success rounded-circle" style="width: 8px; height: 8px;"></div>
                                    <span class="text-muted small fw-bold">ID: ${course.teacherId}</span>
                                </div>
                                <a href="/Courses/Details/${course.id}" class="text-success fw-bold text-decoration-none small letter-spacing-1">
                                    OPEN MODULE <i class="fa-solid fa-chevron-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                `;
                container.innerHTML += card;
            });
        }

        function openCreateModal() {
            document.getElementById('modalTitle').innerText = 'New Module Initialization';
            document.getElementById('courseId').value = '';
            document.getElementById('courseTitle').value = '';
            document.getElementById('courseDesc').value = '';
            courseModal.show();
        }

        function openEditModal(id, title, desc) {
            document.getElementById('modalTitle').innerText = 'Modify Module Specifications';
            document.getElementById('courseId').value = id;
            document.getElementById('courseTitle').value = title;
            document.getElementById('courseDesc').value = desc;
            courseModal.show();
        }

        async function saveCourse() {
            const id = document.getElementById('courseId').value;
            const title = document.getElementById('courseTitle').value;
            const description = document.getElementById('courseDesc').value;

            const courseData = { title, description };
            
            try {
                let response;
                if (id) {
                    courseData.id = parseInt(id);
                    courseData.teacherId = "Teacher1"; 
                    response = await fetch(`${API_URL}/${id}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(courseData)
                    });
                } else {
                    response = await fetch(API_URL, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(courseData)
                    });
                }

                if (response.ok) {
                    courseModal.hide();
                    loadCourses();
                } else {
                    alert('API response error.');
                }
            } catch (error) {
                console.error("API Error:", error);
            }
        }
    </script>
}

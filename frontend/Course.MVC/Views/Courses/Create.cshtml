@model Courses.Models.DTOs.CourseWriteDTO

@{
    ViewData["Title"] = "Create New Course";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg overflow-hidden rounded-4">
                <div class="row g-0">
                    <div class="col-md-4 bg-primary text-white p-5 d-flex flex-column justify-content-center">
                        <div class="mb-4">
                            <i class="fa-solid fa-graduation-cap fa-4x opacity-50"></i>
                        </div>
                        <h2 class="fw-bold mb-3">Share Your Knowledge</h2>
                        <p class="opacity-75">Fill in the details to launch your new course. You can add videos and content after creating the base course.</p>
                        
                        <div class="mt-auto">
                            <div class="d-flex align-items-center mb-3">
                                <i class="fa-solid fa-circle-check me-2"></i>
                                <span class="small">Starts as a Draft</span>
                            </div>
                            <div class="d-flex align-items-center mb-3">
                                <i class="fa-solid fa-circle-check me-2"></i>
                                <span class="small">Add Unlimited Videos</span>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="fa-solid fa-circle-check me-2"></i>
                                <span class="small">Real-time Student Feedback</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-8 p-5 bg-white">
                        <h2 class="fw-bold mb-4">Course <span class="text-primary">Details</span></h2>
                        
                        <form asp-action="Create" method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 small py-2 mb-4 border-0 shadow-sm"></div>
                            
                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <label asp-for="Title" class="form-label fw-bold small text-uppercase">Course Title</label>
                                    <input asp-for="Title" class="form-control border-0 bg-light py-3 px-4" placeholder="e.g. Modern Web Development with React" required />
                                    <span asp-validation-for="Title" class="text-danger small"></span>
                                </div>
                                
                                <div class="col-md-12 mb-3">
                                    <label asp-for="Description" class="form-label fw-bold small text-uppercase">Description</label>
                                    <textarea asp-for="Description" class="form-control border-0 bg-light py-3 px-4" rows="4" placeholder="Describe what students will learn..." required></textarea>
                                    <span asp-validation-for="Description" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="Category" class="form-label fw-bold small text-uppercase">Category</label>
                                    <select asp-for="Category" class="form-select border-0 bg-light py-3 px-4" required>
                                        <option value="">Select Category</option>
                                        <option value="Web Development">Web Development</option>
                                        <option value="Data Science">Data Science</option>
                                        <option value="Design">Design</option>
                                        <option value="Business">Business</option>
                                        <option value="Marketing">Marketing</option>
                                    </select>
                                    <span asp-validation-for="Category" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="Price" class="form-label fw-bold small text-uppercase">Price ($)</label>
                                    <div class="input-group">
                                        <span class="input-group-text border-0 bg-light py-3 px-3">$</span>
                                        <input asp-for="Price" type="number" step="0.01" class="form-control border-0 bg-light py-3 px-4" placeholder="0.00" required />
                                    </div>
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="Duration" class="form-label fw-bold small text-uppercase">Duration</label>
                                    <input asp-for="Duration" class="form-control border-0 bg-light py-3 px-4" placeholder="e.g. 10 hours" required />
                                    <span asp-validation-for="Duration" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="StartDate" class="form-label fw-bold small text-uppercase">Start Date</label>
                                    <input asp-for="StartDate" type="date" class="form-control border-0 bg-light py-3 px-4" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                    <span asp-validation-for="StartDate" class="text-danger small"></span>
                                </div>

                                <div class="col-md-12 mb-4">
                                    <label asp-for="ThumbnailUrl" class="form-label fw-bold small text-uppercase">Thumbnail URL</label>
                                    <input asp-for="ThumbnailUrl" class="form-control border-0 bg-light py-3 px-4" placeholder="https://example.com/image.jpg" />
                                    <span asp-validation-for="ThumbnailUrl" class="text-danger small"></span>
                                </div>
                            </div>
                            
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-lg rounded-pill py-3 fw-bold">Create Course</button>
                                <a asp-action="TeacherDashboard" class="btn btn-link link-secondary text-decoration-none">Cancel and Back to Dashboard</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

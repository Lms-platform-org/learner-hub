@model IEnumerable<Courses.Models.DTOs.CourseReadDTO>

@{
    ViewData["Title"] = "Instructor Dashboard";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="display-5 fw-bold mb-1">Instructor <span class="text-primary">Dashboard</span></h1>
            <p class="text-muted mb-0">Manage your courses, content, and student engagement.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-4 shadow-sm">
            <i class="fa-solid fa-plus me-2"></i>Create New Course
        </a>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="px-4 py-3 border-0">Course Details</th>
                        <th class="px-4 py-3 border-0">Category</th>
                        <th class="px-4 py-3 border-0">Status</th>
                        <th class="px-4 py-3 border-0">Price</th>
                        <th class="px-4 py-3 border-0">Stats</th>
                        <th class="px-4 py-3 border-0">Date Created</th>
                        <th class="px-4 py-3 border-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 py-3 border-bottom-0">
                                    <div class="fw-bold text-dark mb-1">@item.Title</div>
                                    <div class="d-flex align-items-center text-muted small">
                                        <i class="fa-solid fa-clock me-1"></i> @item.Duration
                                        <span class="mx-2">|</span>
                                        <i class="fa-solid fa-calendar me-1"></i> @item.StartDate.ToString("MMM dd, yyyy")
                                    </div>
                                </td>
                                <td class="px-4 py-3 border-bottom-0">
                                    <span class="small fw-medium">@item.Category</span>
                                </td>
                                <td class="px-4 py-3 border-bottom-0">
                                    @if (item.Status == "Published")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">Published</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3 py-2">Draft</span>
                                    }
                                </td>
                                <td class="px-4 py-3 border-bottom-0">
                                    <div class="fw-bold">@item.Price.ToString("C")</div>
                                </td>
                                <td class="px-4 py-3 border-bottom-0">
                                    <div class="d-flex flex-column">
                                        <div class="d-flex align-items-center mb-1">
                                            <span class="me-2 text-primary shadow-sm rounded-circle bg-primary bg-opacity-10 px-2 py-1 small"><i class="fa-solid fa-video"></i></span>
                                            <span class="small">@item.Videos.Count() Videos</span>
                                        </div>
                                        <div class="d-flex align-items-center">
                                            <span class="me-2 text-info shadow-sm rounded-circle bg-info bg-opacity-10 px-2 py-1 small"><i class="fa-solid fa-user-graduate"></i></span>
                                            <span class="small">Students</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 py-3 border-bottom-0 text-muted">
                                    @item.CreatedAt.ToString("MMM dd, yyyy")
                                </td>
                                <td class="px-4 py-3 border-bottom-0 text-end">
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-pill me-1" title="Preview">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill me-1" title="Edit">
                                            <i class="fa-solid fa-edit"></i>
                                        </a>
                                        @if (item.Status == "Draft")
                                        {
                                            <form asp-action="Publish" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-success rounded-pill" title="Publish">
                                                    <i class="fa-solid fa-rocket"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="text-muted mb-3">You haven't created any courses yet.</div>
                                <a asp-action="Create" class="btn btn-sm btn-primary rounded-pill px-4">Start Creating</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

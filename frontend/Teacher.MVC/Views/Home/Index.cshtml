@{
    ViewData["Title"] = "Instructor Overview";
}

<div class="flex justify-between items-end mb-8">
    <div>
        <h1 class="text-4xl font-serif font-bold text-on-surface tracking-tight">Instructor Overview</h1>
        <p class="text-on-surface-variant mt-2 max-w-2xl">Manage your academic curriculum, monitor student progress, and track your institutional performance.</p>
    </div>
    <button class="flex items-center gap-2 bg-primary text-on-primary px-6 py-3 rounded-full font-bold hover:bg-primary-container transition-all shadow-lg shadow-primary/10">
        <span class="material-symbols-outlined">add</span>
        <span>Create New Course</span>
    </button>
</div>

<!-- Stats Grid (StudentMVC Style Cards) -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
    <div class="bg-surface-container border border-outline-variant/30 rounded-[2rem] p-8 relative overflow-hidden group hover:border-primary/50 transition-all duration-300 shadow-sm">
        <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-4">Total Students</p>
        <div class="flex items-baseline gap-2">
            <h2 class="text-4xl font-serif font-bold text-on-surface" id="stat-students">2,842</h2>
            <span class="text-xs font-bold text-primary flex items-center gap-1" id="stat-students-growth">
                <span class="material-symbols-outlined text-[14px]">trending_up</span> +12%
            </span>
        </div>
        <span class="material-symbols-outlined absolute -bottom-4 -right-4 text-8xl text-primary/5 rotate-12 group-hover:scale-110 transition-transform duration-500">group</span>
    </div>

    <div class="bg-surface-container border border-outline-variant/30 rounded-[2rem] p-8 relative overflow-hidden group hover:border-primary/50 transition-all duration-300 shadow-sm">
        <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-4">Course Rating</p>
        <div class="flex items-baseline gap-2">
            <h2 class="text-4xl font-serif font-bold text-on-surface" id="stat-rating">4.92</h2>
            <span class="text-[10px] px-2 py-0.5 rounded-full bg-secondary-container text-on-secondary-container font-bold uppercase tracking-wider">Top 5%</span>
        </div>
        <span class="material-symbols-outlined absolute -bottom-4 -right-4 text-8xl text-primary/5 rotate-12 group-hover:scale-110 transition-transform duration-500">star</span>
    </div>

    <div class="bg-surface-container border border-outline-variant/30 rounded-[2rem] p-8 relative overflow-hidden group hover:border-primary/50 transition-all duration-300 shadow-sm">
        <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-4">Total Revenue</p>
        <div class="flex items-baseline gap-2">
            <h2 class="text-4xl font-serif font-bold text-on-surface" id="stat-revenue">$42.4k</h2>
            <span class="text-xs font-bold text-primary flex items-center gap-1" id="stat-revenue-growth">
                <span class="material-symbols-outlined text-[14px]">payments</span> All-time
            </span>
        </div>
        <span class="material-symbols-outlined absolute -bottom-4 -right-4 text-8xl text-primary/5 rotate-12 group-hover:scale-110 transition-transform duration-500">account_balance_wallet</span>
    </div>

    <div class="bg-surface-container border border-outline-variant/30 rounded-[2rem] p-8 relative overflow-hidden group hover:border-primary/50 transition-all duration-300 shadow-sm">
        <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-4">Active Courses</p>
        <div class="flex items-baseline gap-2">
            <h2 class="text-4xl font-serif font-bold text-on-surface" id="stat-courses">14</h2>
            <span class="text-xs font-bold text-on-surface-variant flex items-center gap-1" id="stat-courses-growth">
                <span class="material-symbols-outlined text-[14px]">pending_actions</span> 2 reviews
            </span>
        </div>
        <span class="material-symbols-outlined absolute -bottom-4 -right-4 text-8xl text-primary/5 rotate-12 group-hover:scale-110 transition-transform duration-500">school</span>
    </div>
</div>

<!-- Main Content Grid -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-10">
    <!-- Left: Course Revenue Chart -->
    <div class="lg:col-span-2 bg-surface-container border border-outline-variant/30 rounded-[2.5rem] p-8 shadow-sm">
        <div class="flex justify-between items-center mb-8">
            <h3 class="text-xl font-serif font-bold">Course Revenue Performance</h3>
            <button class="text-primary hover:bg-primary/10 px-4 py-2 rounded-full text-xs font-bold transition-colors">Detailed View</button>
        </div>
        <div class="h-[350px] w-full relative">
            <canvas id="enrollmentChart"></canvas>
        </div>
    </div>

    <!-- Right: Top Enrolled Courses -->
    <div class="bg-surface-container border border-outline-variant/30 rounded-[2.5rem] p-8 shadow-sm">
        <h3 class="text-xl font-serif font-bold mb-8">Top Enrolled Courses</h3>
        <div class="space-y-6" id="top-enrolled-courses-list">
            <!-- Populated by JS -->
        </div>
        <button class="w-full mt-10 py-4 border-2 border-outline-variant text-on-surface font-bold rounded-2xl hover:bg-surface-container-high hover:border-primary transition-all">View Distribution Report</button>
    </div>
</div>

<!-- Table Section -->
<div class="bg-surface-container border border-outline-variant/30 rounded-[2.5rem] overflow-hidden shadow-sm">
    <div class="p-8 border-b border-outline-variant flex justify-between items-center">
        <h3 class="text-xl font-serif font-bold">Course Management</h3>
        <div class="flex gap-4">
            <select class="bg-surface-container-low border border-outline-variant rounded-full px-6 py-2 text-sm font-medium focus:ring-primary focus:border-primary text-on-surface outline-none">
                <option>All Statuses</option>
                <option>Published</option>
                <option>Draft</option>
            </select>
            <button class="p-2.5 rounded-full border border-outline-variant hover:bg-surface-container-high transition-all">
                <span class="material-symbols-outlined">download</span>
            </button>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead class="bg-surface-container-low/50">
                <tr>
                    <th class="px-8 py-5 text-[10px] uppercase tracking-widest font-bold text-on-surface-variant">Course Name</th>
                    <th class="px-8 py-5 text-[10px] uppercase tracking-widest font-bold text-on-surface-variant">Category</th>
                    <th class="px-8 py-5 text-[10px] uppercase tracking-widest font-bold text-on-surface-variant">Students</th>
                    <th class="px-8 py-5 text-[10px] uppercase tracking-widest font-bold text-on-surface-variant">Status</th>
                    <th class="px-8 py-5 text-[10px] uppercase tracking-widest font-bold text-on-surface-variant text-right">Actions</th>
                </tr>
            </thead>
            <tbody id="course-management-body" class="divide-y divide-outline-variant/10">
                <!-- Populated by JS -->
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", async () => {
            const fallbackData = {
                stats: {
                    totalStudents: 2842,
                    courseRating: 4.92,
                    totalRevenue: 42400,
                    activeCourses: 14,
                    studentGrowthPercentage: 12.0,
                    pendingReviews: 2
                },
                topCourses: [
                    { courseTitle: "Quantum Mechanics III", enrollmentCount: 1240, enrollmentPercentage: 42 },
                    { courseTitle: "AI Ethics", enrollmentCount: 854, enrollmentPercentage: 28 },
                    { courseTitle: "Advanced Thermodynamics", enrollmentCount: 412, enrollmentPercentage: 15 },
                    { courseTitle: "Linear Algebra", enrollmentCount: 300, enrollmentPercentage: 10 },
                    { courseTitle: "Intro to Physics", enrollmentCount: 150, enrollmentPercentage: 5 }
                ],
                courses: [
                    { id: 1, title: "Quantum Mechanics III: Advanced Fields", category: "Physics", studentCount: 1240, status: "Published", updatedText: "Updated 2 days ago" },
                    { id: 2, title: "AI Ethics: A Philosophical Inquiry", category: "Philosophy", studentCount: 854, status: "Published", updatedText: "Updated 1 week ago" },
                    { id: 3, title: "Mathematical Foundations of Topology", category: "Mathematics", studentCount: 0, status: "Draft", updatedText: "Draft saved yesterday" },
                    { id: 4, title: "Advanced Thermodynamics", category: "Chemistry", studentCount: 412, status: "Published", updatedText: "Updated 3 weeks ago" }
                ],
                chart: [
                    { courseTitle: "Quantum Mechanics", revenue: 42000 },
                    { courseTitle: "AI Ethics", revenue: 25000 },
                    { courseTitle: "Linear Algebra", revenue: 18000 },
                    { courseTitle: "Thermodynamics", revenue: 12000 },
                    { courseTitle: "Topology", revenue: 5000 }
                ]
            };

            populateStats(fallbackData.stats);
            populateTopCourses(fallbackData.topCourses);
            populateCourses(fallbackData.courses);
            renderChart(fallbackData.chart);

            try {
                // Future: fetch real data
            } catch (error) {
                console.warn("API connection unavailable, using simulated preview data.");
            }
        });

        function populateStats(stats) {
            document.getElementById("stat-students").innerText = stats.totalStudents.toLocaleString();
            document.getElementById("stat-rating").innerText = stats.courseRating.toFixed(2);
            document.getElementById("stat-revenue").innerText = `$${(stats.totalRevenue / 1000).toFixed(1)}k`;
            document.getElementById("stat-courses").innerText = stats.activeCourses;
        }

        function populateTopCourses(courses) {
            const list = document.getElementById("top-enrolled-courses-list");
            list.innerHTML = "";
            courses.forEach(item => {
                list.innerHTML += `
                    <div class="space-y-3">
                        <div class="flex justify-between items-end">
                            <div>
                                <h4 class="text-sm font-bold">${item.courseTitle}</h4>
                                <p class="text-[10px] text-on-surface-variant font-medium">${item.enrollmentCount.toLocaleString()} Enrolled</p>
                            </div>
                            <span class="text-sm font-serif italic text-primary">${item.enrollmentPercentage}%</span>
                        </div>
                        <div class="h-2 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="h-full bg-primary rounded-full transition-all duration-1000" style="width: ${item.enrollmentPercentage}%"></div>
                        </div>
                    </div>
                `;
            });
        }

        function populateCourses(courses) {
            const body = document.getElementById("course-management-body");
            body.innerHTML = "";
            courses.forEach(c => {
                const statusClass = c.status === "Published" ? "bg-primary/20 text-primary border-primary/30" : "bg-on-surface/5 text-on-surface-variant border-outline-variant/30";
                body.innerHTML += `
                    <tr class="hover:bg-surface-container/30 transition-colors">
                        <td class="px-8 py-6">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-2xl bg-surface-container-high border border-outline-variant/30 flex items-center justify-center text-primary">
                                    <span class="material-symbols-outlined">menu_book</span>
                                </div>
                                <div>
                                    <h4 class="font-bold text-sm text-on-surface">${c.title}</h4>
                                    <p class="text-[10px] text-on-surface-variant font-medium uppercase tracking-widest mt-1">${c.updatedText}</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-8 py-6">
                            <span class="px-4 py-1 rounded-full bg-surface-container-high border border-outline-variant/30 text-[10px] font-bold uppercase tracking-wider text-on-surface-variant">${c.category}</span>
                        </td>
                        <td class="px-8 py-6">
                            <span class="font-serif font-bold text-lg">${c.studentCount.toLocaleString()}</span>
                        </td>
                        <td class="px-8 py-6">
                            <span class="px-4 py-1.5 rounded-full border text-[10px] font-bold uppercase tracking-wider ${statusClass}">${c.status}</span>
                        </td>
                        <td class="px-8 py-6 text-right">
                            <div class="flex justify-end gap-2">
                                <button class="p-2.5 rounded-xl border border-outline-variant hover:border-primary hover:text-primary transition-all">
                                    <span class="material-symbols-outlined text-[20px]">analytics</span>
                                </button>
                                <button class="p-2.5 rounded-xl border border-outline-variant hover:border-primary hover:text-primary transition-all">
                                    <span class="material-symbols-outlined text-[20px]">edit_note</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            });
        }

        function renderChart(dataPoints) {
            const ctx = document.getElementById('enrollmentChart').getContext('2d');
            const isDark = document.documentElement.classList.contains('dark');
            const primaryColor = '#7dd9ab';
            
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: dataPoints.map(d => d.courseTitle),
                    datasets: [{
                        label: 'Revenue ($)',
                        data: dataPoints.map(d => d.revenue),
                        backgroundColor: (context) => {
                            const chart = context.chart;
                            const {ctx, chartArea} = chart;
                            if (!chartArea) return null;
                            const gradient = ctx.createLinearGradient(0, chartArea.bottom, 0, chartArea.top);
                            gradient.addColorStop(0, '#2d6a4f');
                            gradient.addColorStop(1, '#7dd9ab');
                            return gradient;
                        },
                        borderRadius: 12,
                        barThickness: 40,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1c211d',
                            titleFont: { family: 'Newsreader', size: 16 },
                            bodyFont: { family: 'Manrope', size: 13 },
                            padding: 16,
                            cornerRadius: 16,
                            displayColors: false
                        }
                    },
                    scales: {
                        y: {
                            grid: { color: 'rgba(141, 158, 149, 0.1)', drawBorder: false },
                            ticks: { 
                                color: '#8ca395', 
                                font: { family: 'Manrope', size: 11 },
                                callback: (v) => '$' + v/1000 + 'k'
                            }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { 
                                color: '#8ca395', 
                                font: { family: 'Manrope', size: 11 }
                            }
                        }
                    }
                }
            });
        }
    </script>
}

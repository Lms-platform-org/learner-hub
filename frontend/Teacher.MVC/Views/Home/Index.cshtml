@{
    ViewData["Title"] = "Instructor Overview";
}

<div class="instructor-header">
    <div class="instructor-title">
        <h1>Instructor Overview</h1>
        <p>Manage your academic curriculum, monitor student progress, and track your institutional performance.</p>
    </div>
    <button class="btn-create"><i class="fa-solid fa-plus"></i> Create New Course</button>
</div>

<!-- Stats Grid -->
<div class="stats-grid">
    <div class="stat-card">
        <h3>Total Students</h3>
        <div class="value" id="stat-students">2,842</div>
        <div class="sub-value positive" id="stat-students-growth"><i class="fa-solid fa-arrow-trend-up"></i> +12% this semester</div>
        <i class="fa-solid fa-users bg-icon"></i>
    </div>

    <div class="stat-card">
        <h3>Course Rating</h3>
        <div class="value" id="stat-rating">4.92</div>
        <div class="sub-value positive" id="stat-rating-growth"><i class="fa-solid fa-award"></i> Top 5% of Faculty</div>
        <i class="fa-solid fa-star bg-icon"></i>
    </div>

    <div class="stat-card">
        <h3>Total Revenue</h3>
        <div class="value" id="stat-revenue">$0</div>
        <div class="sub-value positive" id="stat-revenue-growth"><i class="fa-solid fa-arrow-trend-up"></i> +$0.0k this month</div>
        <i class="fa-solid fa-money-bill-wave bg-icon"></i>
    </div>

    <div class="stat-card">
        <h3>Active Courses</h3>
        <div class="value" id="stat-courses">14</div>
        <div class="sub-value neutral" id="stat-courses-growth"><i class="fa-solid fa-hourglass-half"></i> 2 pending reviews</div>
        <i class="fa-solid fa-graduation-cap bg-icon"></i>
    </div>
</div>

<!-- Charts Grid -->
<div class="charts-grid">
    <div class="chart-card">
        <div class="chart-card-header">
            <h3>Course Revenue</h3>
        </div>
        <div class="canvas-wrapper" style="height: 300px; position: relative;">
            <canvas id="enrollmentChart"></canvas>
        </div>
    </div>

    <div class="chart-card">
        <div class="chart-card-header">
            <h3>Top Enrolled Courses</h3>
        </div>
        <div class="subject-list" id="top-enrolled-courses-list">
            <!-- Populated by JS -->
        </div>
        <button class="btn-full-report">View Full Report</button>
    </div>
</div>

<!-- Course Management Table -->
<div class="management-card">
    <div class="management-header">
        <h3>Course Management</h3>
        <div class="management-actions">
            <select class="filter-select">
                <option>All Statuses</option>
                <option>Published</option>
                <option>Draft</option>
            </select>
            <button class="btn-export"><i class="fa-solid fa-download"></i></button>
        </div>
    </div>

    <div class="course-table-wrapper">
        <table class="course-table">
            <thead>
                <tr>
                    <th>Course Name</th>
                    <th>Category</th>
                    <th>Students</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="course-management-body">
                <!-- Populated by JS -->
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", async () => {
            // Simulated Fallback Data matching the image perfectly
            const fallbackData = {
                stats: {
                    totalStudents: 2842,
                    courseRating: 4.92,
                    totalRevenue: 42400,
                    activeCourses: 14,
                    studentGrowthPercentage: 12.0,
                    pendingReviews: 2
                },
                topCourses: [
                    { courseTitle: "Quantum Mechanics III", enrollmentCount: 1240, enrollmentPercentage: 42 },
                    { courseTitle: "AI Ethics", enrollmentCount: 854, enrollmentPercentage: 28 },
                    { courseTitle: "Advanced Thermodynamics", enrollmentCount: 412, enrollmentPercentage: 15 },
                    { courseTitle: "Linear Algebra", enrollmentCount: 300, enrollmentPercentage: 10 },
                    { courseTitle: "Intro to Physics", enrollmentCount: 150, enrollmentPercentage: 5 }
                ],
                courses: [
                    { id: 1, title: "Quantum Mechanics III: Advanced Fields", category: "Physics", studentCount: 1240, status: "Published", updatedText: "Updated 2 days ago" },
                    { id: 2, title: "AI Ethics: A Philosophical Inquiry", category: "Philosophy", studentCount: 854, status: "Published", updatedText: "Updated 1 week ago" },
                    { id: 3, title: "Mathematical Foundations of Topology", category: "Mathematics", studentCount: 0, status: "Draft", updatedText: "Draft saved yesterday" },
                    { id: 4, title: "Advanced Thermodynamics", category: "Chemistry", studentCount: 412, status: "Published", updatedText: "Updated 3 weeks ago" }
                ],
                chart: [
                    { courseTitle: "Quantum Mechanics", revenue: 42000 },
                    { courseTitle: "AI Ethics", revenue: 25000 },
                    { courseTitle: "Linear Algebra", revenue: 18000 },
                    { courseTitle: "Thermodynamics", revenue: 12000 },
                    { courseTitle: "Topology", revenue: 5000 }
                ]
            };

            // Render everything
            populateStats(fallbackData.stats);
            populateTopCourses(fallbackData.topCourses);
            populateCourses(fallbackData.courses);
            renderChart(fallbackData.chart);

            // Try fetching real data from local API
            try {
                // Note: In real case, would fetch from: http://localhost:5063/api/TeacherCoursesApi/top-enrolled-courses
            } catch (error) {
                console.warn("API connection unavailable, using simulated preview data.");
            }
        });

        function populateStats(stats) {
            document.getElementById("stat-students").innerText = stats.totalStudents.toLocaleString();
            document.getElementById("stat-rating").innerText = stats.courseRating.toFixed(2);
            document.getElementById("stat-revenue").innerText = `$${(stats.totalRevenue / 1000).toFixed(1)}k`;
            document.getElementById("stat-courses").innerText = stats.activeCourses;
        }

        function populateTopCourses(courses) {
            const list = document.getElementById("top-enrolled-courses-list");
            list.innerHTML = "";
            courses.forEach(item => {
                list.innerHTML += `
                    <div class="subject-item">
                        <div class="subject-info">
                            <span>${item.courseTitle} <small style="color: var(--text-secondary)">(${item.enrollmentCount})</small></span>
                            <strong>${item.enrollmentPercentage}%</strong>
                        </div>
                        <div class="progress-bar-bg">
                            <div class="progress-bar-fill" style="width: ${item.enrollmentPercentage}%"></div>
                        </div>
                    </div>
                `;
            });
        }

        function populateCourses(courses) {
            const body = document.getElementById("course-management-body");
            body.innerHTML = "";
            courses.forEach(c => {
                const statusClass = c.status.toLowerCase();
                const iconClass = c.status.toLowerCase() === "published" ? "fa-check-double" : "fa-file-pen";
                body.innerHTML += `
                    <tr>
                        <td>
                            <div class="course-cell">
                                <div class="course-avatar">
                                    <i class="fa-solid ${iconClass}"></i>
                                </div>
                                <div class="course-info">
                                    <h4>${c.title}</h4>
                                    <span>${c.updatedText}</span>
                                </div>
                            </div>
                        </td>
                        <td><span class="tag-category">${c.category}</span></td>
                        <td><strong>${c.studentCount.toLocaleString()}</strong></td>
                        <td><span class="tag-status ${statusClass}">${c.status}</span></td>
                        <td>
                            <div class="action-icons">
                                <i class="fa-solid fa-chart-line" title="View Analytics"></i>
                                <i class="fa-solid fa-pen" title="Edit Course"></i>
                            </div>
                        </td>
                    </tr>
                `;
            });
        }

        function renderChart(dataPoints) {
            const ctx = document.getElementById('enrollmentChart').getContext('2d');
            
            // Custom styling for the Chart.js bar chart
            const gradient = ctx.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, '#52b788');
            gradient.addColorStop(1, '#2d6a4f');

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: dataPoints.map(d => d.courseTitle || d.label),
                    datasets: [{
                        label: 'Revenue ($)',
                        data: dataPoints.map(d => d.revenue || d.value),
                        backgroundColor: '#2d4635',
                        hoverBackgroundColor: '#52b788',
                        borderRadius: 6,
                        borderSkipped: false,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#141d17',
                            titleColor: '#ffffff',
                            bodyColor: '#8ca395',
                            borderColor: '#22332a',
                            borderWidth: 1
                        }
                    },
                    scales: {
                        y: {
                            display: false,
                            grid: { display: false }
                        },
                        x: {
                            grid: { display: false },
                            ticks: {
                                color: '#8ca395',
                                font: { family: 'Outfit', size: 11 }
                            }
                        }
                    }
                }
            });
        }
    </script>
}

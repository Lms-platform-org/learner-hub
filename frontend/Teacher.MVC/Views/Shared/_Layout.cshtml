<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scholarly - Instructor Overview</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>Scholarly</h2>
                <span class="subtitle">Scholar Central<br><small>Graduate Division</small></span>
            </div>
            <nav class="sidebar-nav">
                <a href="#" class="nav-item"><i class="fa-solid fa-chart-pie"></i> Dashboard</a>
                <a href="#" class="nav-item"><i class="fa-solid fa-book-open"></i> My Courses</a>
                <a href="#" class="nav-item"><i class="fa-solid fa-graduation-cap"></i> Learning</a>
                <a href="#" class="nav-item"><i class="fa-solid fa-comments"></i> Chat</a>
                <a href="#" class="nav-item active"><i class="fa-solid fa-user-tie"></i> Teacher Panel</a>
                <a href="#" class="nav-item"><i class="fa-solid fa-gear"></i> Settings</a>
            </nav>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content">
            <header class="top-header">
                <div class="search-bar">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" placeholder="Search academic resources...">
                </div>
                <div class="user-actions">
                    <div class="notification-bell">
                        <i class="fa-regular fa-bell"></i>
                        <span class="badge"></span>
                    </div>
                    <div class="user-profile">
                        <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100&auto=format&fit=crop&q=60" alt="User Profile">
                    </div>
                </div>
            </header>

            <div class="content-body">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@model LearningPlatformFrontend.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="logo-container" style="justify-content: center; margin-bottom: 2rem;">
            <div style="width: 40px; height: 40px; background: var(--accent-color); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-mortarboard-fill" style="color: white; font-size: 1.5rem;"></i>
            </div>
            <span class="logo-text" style="font-size: 1.5rem;">Scholar Central</span>
        </div>

        <h2 class="auth-title">Welcome Back</h2>
        <p class="auth-subtitle">Please enter your details to sign in</p>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 0.875rem;"></div>
            
            <div class="form-group">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                <span asp-validation-for="Email" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>

            <button type="submit" class="btn-primary mt-3">Sign In</button>
        </form>

        <div class="text-center mt-4">
            <p class="text-muted" style="font-size: 0.875rem;">
                Don't have an account? 
                <a asp-action="Register" style="color: var(--accent-color); font-weight: 600; text-decoration: none;">Create one</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

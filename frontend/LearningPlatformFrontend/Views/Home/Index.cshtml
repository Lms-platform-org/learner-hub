@{
    ViewData["Title"] = "The Horizon - Elevate Your Learning";
}

<div class="landing-page">
    <!-- Hero Section -->
    <header class="hero-section">
        <nav class="landing-nav">
            <div class="logo-container">
                <div
                    style="width: 40px; height: 40px; background: var(--accent-color); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-mortarboard-fill" style="color: white; font-size: 1.5rem;"></i>
                </div>
                <span class="logo-text" style="font-size: 1.5rem;">The Horizon</span>
            </div>
            <div class="nav-auth-buttons">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="d-flex align-items-center gap-3">
                        <span style="color: var(--text-color); font-weight: 500;">Welcome, @User.Identity.Name!</span>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Admin" asp-action="Dashboard" class="btn-outline">Admin Panel</a>
                        }
                        <a asp-controller="Auth" asp-action="Logout" class="btn-primary" style="width: auto; padding: 0.6rem 1.5rem; background: rgba(220, 38, 38, 0.1); color: #dc2626; border: 1px solid #dc2626;">Logout</a>
                    </div>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="btn-outline">Login</a>
                    <a asp-controller="Auth" asp-action="Register" class="btn-primary"
                        style="width: auto; padding: 0.6rem 1.5rem;">Get Started</a>
                }
            </div>
        </nav>

        <div class="hero-content">
            <h1 class="hero-title">Expand Your <span class="text-gradient">Potential</span></h1>
            <p class="hero-subtitle">Access world-class education from the comfort of your home. Join thousands of
                students on their journey to excellence.</p>
            <div class="hero-actions">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Home" asp-action="Dashboard" class="btn-primary"
                        style="width: auto; padding: 1rem 2.5rem; font-size: 1.1rem;">Start Learning</a>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Register" class="btn-primary"
                        style="width: auto; padding: 1rem 2.5rem; font-size: 1.1rem;">Explore Courses</a>
                }
                <button class="btn-secondary" style="width: auto; padding: 1rem 2rem;">Watch Demo</button>
            </div>
        </div>
    </header>

    <!-- Features Section -->
    <section class="features-grid">
        <div class="feature-card">
            <i class="bi bi-lightning-charge-fill"></i>
            <h3>Fast Learning</h3>
            <p>Optimized curriculum designed for rapid skill acquisition and retention.</p>
        </div>
        <div class="feature-card">
            <i class="bi bi-people-fill"></i>
            <h3>Expert Mentors</h3>
            <p>Learn directly from industry leaders and academic veterans.</p>
        </div>
        <div class="feature-card">
            <i class="bi bi-award-fill"></i>
            <h3>Certified</h3>
            <p>Earn industry-recognized certificates upon course completion.</p>
        </div>
    </section>
</div>

<style>
    .landing-page {
        overflow-x: hidden;
    }

    .landing-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 5%;
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
    }

    .nav-auth-buttons {
        display: flex;
        gap: 1.5rem;
        align-items: center;
    }

    .btn-outline {
        color: var(--text-color);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.3s;
    }

    .btn-outline:hover {
        color: var(--accent-color);
    }

    .hero-section {
        min-height: 100vh;
        background: radial-gradient(circle at 70% 30%, rgba(52, 211, 153, 0.1) 0%, transparent 50%),
            radial-gradient(circle at 10% 80%, rgba(52, 211, 153, 0.05) 0%, transparent 40%);
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 10rem;
        text-align: center;
    }

    .hero-content {
        max-width: 800px;
        padding: 0 1.5rem;
        margin-bottom: 5rem;
    }

    .hero-title {
        font-size: clamp(3rem, 8vw, 5rem);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        color: var(--text-color);
    }

    .text-gradient {
        background: linear-gradient(135deg, var(--accent-color), #3b82f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .hero-subtitle {
        font-size: 1.25rem;
        color: var(--text-muted);
        margin-bottom: 3rem;
        line-height: 1.6;
    }

    .hero-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
    }

    /* Features Section */
    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        padding: 5rem 10%;
        background: var(--sidebar-bg);
    }

    .feature-card {
        padding: 3rem 2rem;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 1.5rem;
        text-align: center;
        transition: transform 0.3s;
    }

    .feature-card:hover {
        transform: translateY(-10px);
    }

    .feature-card i {
        font-size: 2.5rem;
        color: var(--accent-color);
        margin-bottom: 1.5rem;
        display: block;
    }

    .feature-card h3 {
        margin-bottom: 1rem;
        font-weight: 700;
    }

    .feature-card p {
        color: var(--text-muted);
        line-height: 1.6;
    }

    [data-theme="dark"] .hero-section {
        background: radial-gradient(circle at 70% 30%, rgba(52, 211, 153, 0.05) 0%, transparent 50%),
            #070d0b;
    }
</style>

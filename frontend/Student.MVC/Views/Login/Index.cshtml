@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – LearnHub</title>
    
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Manrope:wght@200..800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-dim": "#101411",
                        "on-secondary": "#003549",
                        "on-surface": "#dfe4de",
                        "inverse-on-surface": "#2d322e",
                        "surface-container-lowest": "#0a0f0c",
                        "surface-container-highest": "#313632",
                        "surface-container": "#1c211d",
                        "on-secondary-fixed-variant": "#004c68",
                        "surface-tint": "#7dd9ab",
                        "surface": "#101411",
                        "secondary": "#88cff7",
                        "outline-variant": "#3e4942",
                        "on-secondary-fixed": "#001e2c",
                        "outline": "#88938b",
                        "on-error": "#690005",
                        "primary-fixed": "#99f5c6",
                        "on-primary": "#003824",
                        "inverse-primary": "#006c49",
                        "on-tertiary-container": "#531017",
                        "secondary-container": "#006386",
                        "on-surface-variant": "#bec9c0",
                        "on-tertiary-fixed-variant": "#7a2d32",
                        "tertiary-container": "#d57578",
                        "error-container": "#93000a",
                        "surface-bright": "#353a37",
                        "on-primary-container": "#00311f",
                        "primary-container": "#45a178",
                        "primary": "#7dd9ab",
                        "on-tertiary": "#5c171d",
                        "on-primary-fixed-variant": "#005236",
                        "error": "#ffb4ab",
                        "tertiary-fixed": "#ffdad9",
                        "primary-fixed-dim": "#7dd9ab",
                        "on-secondary-container": "#a2dcff",
                        "on-error-container": "#ffdad6",
                        "on-tertiary-fixed": "#3f020b",
                        "tertiary-fixed-dim": "#ffb3b3",
                        "on-background": "#dfe4de",
                        "secondary-fixed": "#c3e8ff",
                        "surface-variant": "#313632",
                        "tertiary": "#ffb3b3",
                        "background": "#101411",
                        "on-primary-fixed": "#002113",
                        "secondary-fixed-dim": "#88cff7",
                        "surface-container-high": "#262b28",
                        "surface-container-low": "#181d1a",
                        "inverse-surface": "#dfe4de"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "container-max": "1280px",
                        "gutter": "24px",
                        "margin-mobile": "16px",
                        "margin-desktop": "40px",
                        "unit": "8px",
                        "stack-md": "16px",
                        "stack-lg": "32px",
                        "stack-sm": "8px"
                    },
                    "fontFamily": {
                        "h2": ["Newsreader"],
                        "body-lg": ["Manrope"],
                        "body-md": ["Manrope"],
                        "h3": ["Newsreader"],
                        "h1": ["Newsreader"],
                        "label-sm": ["Manrope"],
                        "sans": ["Manrope", "sans-serif"],
                        "serif": ["Newsreader", "serif"]
                    },
                    "fontSize": {
                        "h2": ["36px", {"lineHeight": "1.2", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                        "body-lg": ["18px", {"lineHeight": "1.6", "letterSpacing": "0", "fontWeight": "400"}],
                        "body-md": ["16px", {"lineHeight": "1.6", "letterSpacing": "0", "fontWeight": "400"}],
                        "h3": ["28px", {"lineHeight": "1.3", "letterSpacing": "0", "fontWeight": "500"}],
                        "h1": ["48px", {"lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "600"}],
                        "label-sm": ["13px", {"lineHeight": "1.4", "letterSpacing": "0.05em", "fontWeight": "600"}]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        /* Loading animation for the login button */
        .loading-dots::after { content: ''; animation: dots 1.2s infinite; }
        @@keyframes dots { 0%{content:'.'} 33%{content:'..'} 66%{content:'...'} }
        @@keyframes slideIn { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
        .login-card { animation: slideIn 0.45s cubic-bezier(0.34,1.56,0.64,1); }
    </style>
</head>
<body class="bg-gray-50 dark:bg-[#0F1714] text-gray-900 dark:text-[#dfe4de] font-sans antialiased min-h-screen flex items-center justify-center p-6 selection:bg-primary/30 selection:text-primary transition-colors duration-300 relative overflow-hidden">
    
    <!-- Decorative Background Elements -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] bg-emerald-500/5 dark:bg-primary/5 rounded-full blur-[100px]"></div>
        <div class="absolute top-[60%] -right-[10%] w-[40%] h-[40%] bg-blue-500/5 dark:bg-secondary/5 rounded-full blur-[80px]"></div>
    </div>

    <!-- Theme Toggle (Absolute) -->
    <button id="darkToggle" onclick="toggleDark()" class="absolute top-6 right-6 p-3 bg-white dark:bg-[#16211D] border border-gray-200 dark:border-[#23332D] shadow-sm hover:bg-gray-50 dark:hover:bg-[#1B2A24] transition-colors rounded-full text-gray-500 dark:text-[#A7B8B0] z-10">
        <span class="material-symbols-outlined" id="darkIcon">light_mode</span>
    </button>

    <div class="w-full max-w-md relative z-10">
        <div class="login-card bg-white dark:bg-[#16211D] border border-gray-200 dark:border-[#23332D] rounded-2xl shadow-2xl overflow-hidden">
            
            <!-- Hero Header -->
            <div class="bg-emerald-900 dark:bg-[#101411] border-b border-emerald-800 dark:border-[#23332D] p-8 text-center relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                <div class="relative z-10">
                    <h1 class="font-serif text-3xl font-bold text-emerald-50 dark:text-[#E6F1EC] flex items-center justify-center gap-3 mb-2">
                        <span class="material-symbols-outlined text-primary text-[32px]">school</span>
                        LearnHub
                    </h1>
                    <p class="text-emerald-200/70 dark:text-[#A7B8B0] text-sm">Advanced Academic Platform</p>
                </div>
            </div>

            <!-- Login Form Area -->
            <div class="p-8">
                @if (TempData["Error"] != null)
                {
                    <div class="mb-6 p-4 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-800 dark:text-red-300 text-sm flex items-start gap-3">
                        <span class="material-symbols-outlined">error</span>
                        <span>@TempData["Error"]</span>
                    </div>
                }
                <div id="client-error" class="hidden mb-6 p-4 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-800 dark:text-red-300 text-sm flex items-start gap-3"></div>

                <form id="loginForm" method="post" asp-action="Submit" asp-controller="Login" novalidate class="space-y-5">
                    <div>
                        <label for="name" class="block text-sm font-semibold text-gray-700 dark:text-[#A7B8B0] mb-1.5">Full Name</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400 dark:text-[#88938b]">
                                <span class="material-symbols-outlined text-[20px]">person</span>
                            </div>
                            <input type="text" id="name" name="name" required autocomplete="name" placeholder="E.g. Dr. Julian Vossen" 
                                class="w-full pl-11 pr-4 py-2.5 bg-gray-50 dark:bg-[#0F1714] border border-gray-200 dark:border-[#23332D] text-gray-900 dark:text-[#E6F1EC] rounded-xl focus:ring-1 focus:ring-primary focus:border-primary focus:outline-none transition-colors" />
                        </div>
                    </div>
                    
                    <div>
                        <label for="email" class="block text-sm font-semibold text-gray-700 dark:text-[#A7B8B0] mb-1.5">Institutional Email</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400 dark:text-[#88938b]">
                                <span class="material-symbols-outlined text-[20px]">mail</span>
                            </div>
                            <input type="email" id="email" name="email" required autocomplete="email" placeholder="julian@university.edu" 
                                class="w-full pl-11 pr-4 py-2.5 bg-gray-50 dark:bg-[#0F1714] border border-gray-200 dark:border-[#23332D] text-gray-900 dark:text-[#E6F1EC] rounded-xl focus:ring-1 focus:ring-primary focus:border-primary focus:outline-none transition-colors" />
                        </div>
                    </div>

                    <div class="flex items-center gap-4 my-6">
                        <div class="h-px bg-gray-200 dark:bg-[#23332D] flex-1"></div>
                        <span class="text-xs text-gray-400 dark:text-[#88938b] font-medium uppercase tracking-wider">Advanced (Optional)</span>
                        <div class="h-px bg-gray-200 dark:bg-[#23332D] flex-1"></div>
                    </div>

                    <div class="bg-blue-50 dark:bg-[#0F1714] border border-blue-100 dark:border-[#23332D] rounded-xl p-4">
                        <div class="flex items-center justify-between mb-2">
                            <label for="token" class="text-xs font-semibold text-blue-800 dark:text-[#A7B8B0]">Authentication Token</label>
                            <button type="button" onclick="useDevToken()" class="text-[10px] uppercase tracking-wider font-bold bg-blue-100 dark:bg-primary/20 text-blue-700 dark:text-primary px-2 py-1 rounded">
                                Dev Access
                            </button>
                        </div>
                        <textarea id="token" name="token" rows="2" placeholder="Paste your JWT token here (leave blank for local dev mode)" 
                            class="w-full px-3 py-2 text-xs font-mono bg-white dark:bg-[#16211D] border border-blue-200 dark:border-[#23332D] text-gray-800 dark:text-[#A7B8B0] rounded-lg focus:ring-1 focus:ring-primary focus:border-primary focus:outline-none transition-colors resize-y"></textarea>
                        <p class="text-[11px] text-blue-600/70 dark:text-[#88938b] mt-1.5 flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">info</span>
                            Using dev mode auto-injects an offline student profile.
                        </p>
                    </div>

                    <button type="submit" id="submitBtn" class="w-full bg-primary text-on-primary py-3 px-4 rounded-xl font-bold text-sm hover:opacity-90 transition-all flex items-center justify-center gap-2 mt-4 shadow-lg shadow-primary/20">
                        Access Dashboard
                        <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                    </button>
                </form>
            </div>
            
            <div class="px-8 py-5 bg-gray-50 dark:bg-[#0F1714]/50 border-t border-gray-200 dark:border-[#23332D] text-center">
                <p class="text-xs text-gray-500 dark:text-[#88938b]">
                    By signing in, you agree to the <a href="#" class="text-primary hover:underline">Terms of Inquiry</a> and <a href="#" class="text-primary hover:underline">Privacy Charter</a>.
                </p>
            </div>
        </div>
    </div>

    <script>
        // ── DARK MODE TOGGLE ──
        function toggleDark() {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('lh-theme', isDark ? 'dark' : 'light');
            updateDarkIcon(isDark);
        }
        function updateDarkIcon(isDark) {
            const icon = document.getElementById('darkIcon');
            if (icon) icon.textContent = isDark ? 'light_mode' : 'dark_mode';
        }
        (function () {
            const savedTheme = localStorage.getItem('lh-theme');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            const isDark = savedTheme === 'dark' || (!savedTheme && prefersDark);
            
            if (isDark) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
            updateDarkIcon(isDark);
        })();

        // ── DEV MODE FILLER ──
        function useDevToken() {
            document.getElementById('token').value = '';
            document.getElementById('name').value = document.getElementById('name').value || 'Dr. Julian Vossen';
            document.getElementById('email').value = document.getElementById('email').value || 'julian@scholarly.edu';
            
            // Auto focus submit button to indicate readiness
            document.getElementById('submitBtn').focus();
        }

        // ── FORM VALIDATION ──
        document.getElementById('loginForm').addEventListener('submit', function (e) {
            const name = document.getElementById('name').value.trim();
            const email = document.getElementById('email').value.trim();
            const errBox = document.getElementById('client-error');

            if (name.length < 2) {
                e.preventDefault();
                errBox.innerHTML = '<span class="material-symbols-outlined">error</span><span>Please provide your full institutional name.</span>';
                errBox.style.display = 'flex';
                document.getElementById('name').focus();
                return;
            }
            if (!email.includes('@@')) {
                e.preventDefault();
                errBox.innerHTML = '<span class="material-symbols-outlined">error</span><span>A valid email address is required for access.</span>';
                errBox.style.display = 'flex';
                document.getElementById('email').focus();
                return;
            }

            // Hide error box if shown
            errBox.style.display = 'none';

            // Store in sessionStorage for global navbar use
            sessionStorage.setItem('lh-name', name);
            sessionStorage.setItem('lh-email', email);
            const jwt = document.getElementById('token').value.trim();
            if (jwt) sessionStorage.setItem('lh-jwt', jwt);

            // Loading state
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = 'Authenticating<span class="loading-dots"></span>';
            btn.classList.add('opacity-70', 'cursor-not-allowed');
        });
    </script>
</body>
</html>

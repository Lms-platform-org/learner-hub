@using LearningPlatform.StudentService.WebApp.Models.DTOs
@model ProfileDto
@{
    ViewData["Title"] = "My Profile";
    var skillsString = Model.Skills != null ? string.Join(", ", Model.Skills) : "";
}

<style>
    .profile-hero { margin-bottom: 2rem; position: relative; }
    .profile-cover { height: 180px; border-radius: 20px; background: linear-gradient(135deg, #022c22, #064e3b); position: relative; overflow: hidden; }
    body.dark .profile-cover { background: linear-gradient(135deg, #0F1714, #1B2A24); border: 1px solid var(--border-dark); }
    .profile-cover::after { content:''; position:absolute; inset:0; background: url('https://www.transparenttextures.com/patterns/cubes.png'); opacity: 0.1; }
    .profile-avatar-wrap { display: flex; flex-direction: column; align-items: flex-start; margin-top: -4rem; padding-left: 2rem; margin-bottom: 2.5rem; position: relative; z-index: 10; gap: 0.5rem; }
    .profile-avatar { width: 120px; height: 120px; border-radius: 50%; background: var(--card-bg); border: 5px solid var(--bg); display: flex; align-items: center; justify-content: center; font-size: 3.5rem; color: var(--primary); box-shadow: 0 10px 25px rgba(0,0,0,0.1); z-index: 2; position: relative; }
    body.dark .profile-avatar { background: var(--card-bg-dark); border-color: var(--bg-dark); box-shadow: 0 10px 25px rgba(0,0,0,0.3); }
    .profile-avatar-badge { position: absolute; bottom: 5px; right: 5px; width: 30px; height: 30px; background: var(--success); border-radius: 50%; border: 3px solid var(--bg); display: flex; align-items: center; justify-content: center; color: white; font-size: 0.8rem; }
    body.dark .profile-avatar-badge { border-color: var(--bg-dark); }
    .profile-title { flex: 1; padding-top: 0.5rem; }
    .profile-title h1 { font-size: 2rem; font-weight: 800; margin: 0; color: var(--text); line-height: 1.2; font-family: 'Newsreader', serif; }
    body.dark .profile-title h1 { color: var(--text-dark); }
    .profile-title p { color: var(--muted); margin: 0; font-size: 0.95rem; font-weight: 600; margin-top: 0.2rem; }
    
    .profile-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
    @@media (min-width: 992px) { .profile-grid { grid-template-columns: 2fr 1fr; } }
    
    .profile-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 1.8rem; box-shadow: 0 2px 12px rgba(0,0,0,0.03); }
    body.dark .profile-card { background: var(--card-bg-dark); border-color: var(--border-dark); }
    .card-title { font-size: 1.2rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; color: var(--text); }
    body.dark .card-title { color: var(--text-dark); }
    
    .form-group { margin-bottom: 1.3rem; }
    .form-group label { display: block; font-size: 0.88rem; font-weight: 600; color: var(--muted); margin-bottom: 0.4rem; }
    .form-control { width: 100%; padding: 0.75rem 1rem; border: 2px solid var(--border); border-radius: 10px; background: var(--card-bg); color: var(--text); font-size: 0.95rem; transition: all 0.2s; outline: none; }
    body.dark .form-control { background: var(--card-bg-dark); border-color: var(--border-dark); color: var(--text-dark); }
    .form-control:focus { border-color: var(--primary); background: var(--card-bg); box-shadow: 0 0 0 3px rgba(99,102,241,0.1); }
    body.dark .form-control:focus { background: var(--card-bg-dark); }
    .form-control::placeholder { color: #cbd5e1; }
    body.dark .form-control::placeholder { color: #475569; }
    
    /* Handle Autofill */
    input:-webkit-autofill,
    input:-webkit-autofill:hover, 
    input:-webkit-autofill:focus, 
    input:-webkit-autofill:active {
        -webkit-text-fill-color: var(--text) !important;
        -webkit-box-shadow: 0 0 0 30px var(--card-bg) inset !important;
        transition: background-color 5000s ease-in-out 0s;
    }
    body.dark input:-webkit-autofill,
    body.dark input:-webkit-autofill:hover, 
    body.dark input:-webkit-autofill:focus, 
    body.dark input:-webkit-autofill:active {
        -webkit-text-fill-color: var(--text-dark) !important;
        -webkit-box-shadow: 0 0 0 30px var(--card-bg-dark) inset !important;
    }

    textarea.form-control { resize: vertical; min-height: 100px; }
    
    .skills-display { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }
    .skill-chip { padding: 0.35rem 0.8rem; border-radius: 20px; background: rgba(99,102,241,0.1); color: var(--primary); font-size: 0.82rem; font-weight: 600; display: inline-flex; align-items: center; gap: 0.3rem; }
    body.dark .skill-chip { background: rgba(99,102,241,0.2); }
    
    .btn-save { width: 100%; padding: 0.85rem; border: none; border-radius: 10px; background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; font-weight: 700; font-size: 1rem; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 0.5rem; }
    .btn-save:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(99,102,241,0.3); }
    
    .stat-list { list-style: none; padding: 0; margin: 0; }
    .stat-item { display: flex; align-items: center; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--border); }
    .stat-item:last-child { border-bottom: none; }
    body.dark .stat-item { border-color: var(--border-dark); }
    .stat-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; }
    .stat-info { flex: 1; }
    .stat-lbl { font-size: 0.82rem; color: var(--muted); font-weight: 500; }
    .stat-val { font-size: 1.05rem; font-weight: 700; color: var(--text); }
    body.dark .stat-val { color: var(--text-dark); }
</style>

<div class="profile-hero fade-up">
    <div class="profile-cover"></div>
    <div class="profile-avatar-wrap">
        <div class="profile-avatar">
            <i class="bi bi-person-fill"></i>
            <div class="profile-avatar-badge" title="Verified Student"><i class="bi bi-check-lg"></i></div>
        </div>
        <div class="profile-title">
            <h1 id="display-name">@(string.IsNullOrEmpty(Model.FullName) ? "Student" : Model.FullName)</h1>
            <p><i class="bi bi-envelope-fill me-1"></i> <span id="display-email">@(Context.Session.GetString("email") ?? "")</span></p>
        </div>
    </div>
</div>

<div class="profile-grid">
    <!-- Left Col: Form -->
    <div class="profile-card fade-up" style="animation-delay: 0.1s;">
        <div class="card-title">
            <i class="bi bi-person-lines-fill" style="color:var(--primary);"></i> Personal Information
        </div>
        
        <form method="post" asp-action="Save">
            <div class="row">
                <div class="col-md-6 form-group">
                    <label for="FullName">Full Name</label>
                    <input type="text" id="FullName" name="FullName" class="form-control" value="@Model.FullName" required>
                </div>
                <div class="col-md-6 form-group">
                    <label for="PreferredLevel">Learning Level</label>
                    <select id="PreferredLevel" name="PreferredLevel" class="form-control">
                        @if (Model.PreferredLevel == "Beginner") { <option value="Beginner" selected>Beginner</option> } else { <option value="Beginner">Beginner</option> }
                        @if (Model.PreferredLevel == "Intermediate") { <option value="Intermediate" selected>Intermediate</option> } else { <option value="Intermediate">Intermediate</option> }
                        @if (Model.PreferredLevel == "Advanced") { <option value="Advanced" selected>Advanced</option> } else { <option value="Advanced">Advanced</option> }
                    </select>
                </div>
            </div>
            
            <div class="form-group">
                <label for="Bio">Bio / About Me</label>
                <textarea id="Bio" name="Bio" class="form-control" placeholder="Tell us a little bit about yourself and your learning goals...">@Model.Bio</textarea>
            </div>
            
            <div class="form-group">
                <label for="SkillsInput">Skills (comma separated)</label>
                <input type="text" id="SkillsInput" name="SkillsInput" class="form-control" value="@skillsString" placeholder="e.g. C#, Python, React, UI/UX">
                @if (Model.Skills?.Any() == true)
                {
                    <div class="skills-display mt-2">
                        @foreach (var s in Model.Skills)
                        {
                            <span class="skill-chip"><i class="bi bi-code-slash"></i> @s</span>
                        }
                    </div>
                }
            </div>
            
            <div class="mt-4 pt-2">
                <button type="submit" class="btn-save">
                    <i class="bi bi-check2-circle"></i> Save Changes
                </button>
            </div>
        </form>
    </div>

    <!-- Right Col: Stats -->
    <div class="profile-card fade-up" style="animation-delay: 0.2s;">
        <div class="card-title">
            <i class="bi bi-bar-chart-fill" style="color:var(--secondary);"></i> Account Stats
        </div>
        
        <ul class="stat-list">
            <li class="stat-item">
                <div class="stat-icon" style="background:rgba(16,185,129,0.1); color:var(--success);"><i class="bi bi-calendar2-check-fill"></i></div>
                <div class="stat-info">
                    <div class="stat-lbl">Joined Date</div>
                    <div class="stat-val">@Model.JoinedDate.ToString("MMM dd, yyyy")</div>
                </div>
            </li>
            <li class="stat-item">
                <div class="stat-icon" style="background:rgba(99,102,241,0.1); color:var(--primary);"><i class="bi bi-mortarboard-fill"></i></div>
                <div class="stat-info">
                    <div class="stat-lbl">Role</div>
                    <div class="stat-val">Student</div>
                </div>
            </li>
            <li class="stat-item">
                <div class="stat-icon" style="background:rgba(245,158,11,0.1); color:var(--warning);"><i class="bi bi-lightning-charge-fill"></i></div>
                <div class="stat-info">
                    <div class="stat-lbl">Status</div>
                    <div class="stat-val">Active Learner</div>
                </div>
            </li>
        </ul>
        
        <div class="mt-4 p-3 rounded" style="background:rgba(139,92,246,0.08); border:1px dashed rgba(139,92,246,0.3);">
            <div style="font-size:0.85rem; font-weight:600; color:var(--secondary); margin-bottom:0.4rem;">
                <i class="bi bi-shield-lock-fill"></i> Privacy & Security
            </div>
            <div style="font-size:0.75rem; color:var(--muted); line-height:1.5;">
                Your profile information is private by default. Only you can view your learning progress and saved items.
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Load email from session
    const email = sessionStorage.getItem('lh-email');
    if (email) document.getElementById('display-email').textContent = email;
</script>
}

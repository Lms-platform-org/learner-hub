@using LearningPlatform.StudentService.WebApp.Models.DTOs
@model ProfileDto

@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card p-4">
            <div class="text-center mb-4">
                <i class="bi bi-person-circle display-3 text-primary"></i>
                <h4 class="fw-bold mt-2">My Profile</h4>
                <p class="text-muted small">Update your learning preferences</p>
            </div>

            <form method="post" asp-action="Save">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Full Name</label>
                    <input name="FullName" value="@Model.FullName" class="form-control"
                           placeholder="Your full name" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Bio</label>
                    <textarea name="Bio" class="form-control" rows="3"
                              placeholder="Tell us about yourself...">@Model.Bio</textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Skills</label>
                    <input name="SkillsInput" id="skillsInput" class="form-control"
                           placeholder="e.g. Python, SQL, React (comma separated)"
                           value="@string.Join(", ", Model.Skills)" />
                    <small class="text-muted">Separate skills with commas</small>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Preferred Level</label>
                    <select name="PreferredLevel" class="form-select">
                        <option value="Beginner" selected="@(Model.PreferredLevel == "Beginner")">Beginner</option>
                        <option value="Intermediate" selected="@(Model.PreferredLevel == "Intermediate")">Intermediate</option>
                        <option value="Advanced" selected="@(Model.PreferredLevel == "Advanced")">Advanced</option>
                    </select>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-2"></i>Save Profile
                    </button>
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

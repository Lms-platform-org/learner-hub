@using LearningPlatform.StudentService.WebApp.Models.DTOs
@model LearningPlatform.StudentService.WebApp.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var name = Context.Session.GetString("name") ?? "Student";
}

<!-- Hero Section -->
<div class="mb-stack-lg animate-[fadeUp_0.5s_ease_forwards]">
    <h1 class="font-h1 text-h1 text-on-surface mb-2 tracking-tight flex items-center gap-3">
        Good morning, <span class="text-primary" id="hero-name">@name</span> 
        <span class="text-h2">👋</span>
    </h1>
    <p class="font-body-lg text-on-surface-variant">Here's your academic overview for today</p>
</div>

<!-- XP Bar -->
@if (Model.TotalXP > 0)
{
    var level = Model.TotalXP < 500 ? "Beginner" : Model.TotalXP < 1500 ? "Intermediate" : "Advanced";
    var nextXp = Model.TotalXP < 500 ? 500 : Model.TotalXP < 1500 ? 1500 : 5000;
    var pct = Math.Min((int)((double)Model.TotalXP / nextXp * 100), 100);

    <div class="bg-amber-50 dark:bg-amber-900/10 border border-amber-200 dark:border-amber-900/30 rounded-2xl p-6 mb-8 flex items-center gap-6 animate-[fadeUp_0.6s_ease_forwards]">
        <div class="w-14 h-14 bg-gradient-to-br from-amber-400 to-amber-600 rounded-xl flex items-center justify-center text-white shrink-0 shadow-lg shadow-amber-500/20">
            <span class="material-symbols-outlined text-[32px]">bolt</span>
        </div>
        <div class="flex-1">
            <div class="flex items-baseline gap-2">
                <span class="text-3xl font-bold text-amber-600 dark:text-amber-500 font-serif" id="xp-number">@Model.TotalXP</span>
                <span class="text-amber-700/70 dark:text-amber-500/70 font-bold text-sm tracking-wider">XP</span>
            </div>
            <div class="text-sm font-medium text-amber-800/80 dark:text-amber-200/60 mt-1">Total Experience Points earned</div>
            <div class="text-xs text-amber-700/60 dark:text-amber-400/50 mt-1">
                Level: <strong class="text-amber-800 dark:text-amber-300">@level</strong> · @(nextXp - Model.TotalXP) XP to next level
            </div>
        </div>
        <div class="w-40 shrink-0">
            <div class="text-xs font-bold text-amber-800 dark:text-amber-400 text-right mb-1.5">@pct%</div>
            <div class="h-2.5 bg-amber-200/50 dark:bg-amber-900/40 rounded-full overflow-hidden">
                <div class="h-full bg-gradient-to-r from-amber-400 to-amber-500 rounded-full transition-all duration-1000 ease-out" style="width: @pct%"></div>
            </div>
        </div>
    </div>
}

<!-- Stats Grid -->
@if (Model.EnrolledCount > 0 || Model.CompletedCount > 0 || Model.InProgressCount > 0 || Model.TotalBookmarks > 0)
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-gutter mb-10">
        <!-- Enrolled -->
        <div class="bg-gray-100 dark:bg-[#1B2A24] p-8 rounded-lg border border-gray-200 dark:border-[#23332D] shadow-sm">
            <span class="block text-3xl font-h2 text-primary font-bold mb-1">@Model.EnrolledCount</span>
            <span class="text-sm font-label-sm text-gray-500 dark:text-on-surface-variant">COURSES ENROLLED</span>
        </div>
        
        <!-- Completed -->
        <div class="bg-gray-100 dark:bg-[#1B2A24] p-8 rounded-lg border border-gray-200 dark:border-[#23332D] shadow-sm">
            <span class="block text-3xl font-h2 text-primary font-bold mb-1">@Model.CompletedCount</span>
            <span class="text-sm font-label-sm text-gray-500 dark:text-on-surface-variant">COMPLETED</span>
        </div>

        <!-- In Progress -->
        <div class="bg-gray-100 dark:bg-[#1B2A24] p-8 rounded-lg border border-gray-200 dark:border-[#23332D] shadow-sm">
            <span class="block text-3xl font-h2 text-primary font-bold mb-1">@Model.InProgressCount</span>
            <span class="text-sm font-label-sm text-gray-500 dark:text-on-surface-variant">IN PROGRESS</span>
        </div>

        <!-- Bookmarks -->
        <div class="bg-gray-100 dark:bg-[#1B2A24] p-8 rounded-lg border border-gray-200 dark:border-[#23332D] shadow-sm">
            <span class="block text-3xl font-h2 text-primary font-bold mb-1">@Model.TotalBookmarks</span>
            <span class="text-sm font-label-sm text-gray-500 dark:text-on-surface-variant">BOOKMARKS</span>
        </div>
    </div>
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left Column: Continue Watching -->
    <div class="lg:col-span-2 space-y-8">
        
        <div class="bg-white dark:bg-[#16211D] border border-gray-200 dark:border-[#23332D] rounded-2xl p-6 shadow-sm">
            <div class="flex items-center justify-between mb-6">
                <h2 class="font-serif font-bold text-xl text-gray-900 dark:text-[#E6F1EC] flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">play_circle</span>
                    Continue Watching
                </h2>
                @if (Model.ContinueWatching?.Any() == true)
                {
                    <span class="bg-primary/10 text-primary border border-primary/20 text-xs font-bold px-2 py-1 rounded-md">@Model.ContinueWatching.Count courses</span>
                }
            </div>

            @if (Model.ContinueWatching?.Any() == true)
            {
                <div class="space-y-4">
                    @foreach (var p in Model.ContinueWatching)
                    {
                        <a href="/Enrollment/MyCourses" class="flex items-center gap-4 p-4 rounded-xl border border-gray-200 dark:border-[#23332D] bg-gray-50/50 dark:bg-[#0F1714]/50 hover:border-primary/50 dark:hover:border-primary/50 transition-colors group">
                            <div class="w-14 h-14 rounded-lg bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 flex items-center justify-center shrink-0 group-hover:bg-primary group-hover:text-on-primary transition-colors">
                                <span class="material-symbols-outlined">play_arrow</span>
                            </div>
                            <div class="flex-1 min-w-0">
                                <h3 class="font-bold text-gray-900 dark:text-[#E6F1EC] truncate font-serif">Course #@p.LastLessonId</h3>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="text-[10px] font-bold uppercase tracking-wider bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 px-1.5 py-0.5 rounded">In Progress</span>
                                    <span class="text-xs text-gray-500 dark:text-[#A7B8B0]">Lesson @p.LastLessonId · @(TimeSpan.FromSeconds(p.LastVideoTimestampSeconds).ToString(@"mm\:ss"))</span>
                                </div>
                                <div class="h-1.5 w-full bg-gray-200 dark:bg-[#23332D] rounded-full mt-3 overflow-hidden">
                                    <div class="h-full bg-primary rounded-full transition-all duration-1000" style="width: @p.Percentage%"></div>
                                </div>
                            </div>
                            <div class="text-lg font-bold text-primary shrink-0 ml-4">@p.Percentage%</div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-12 px-4 border border-dashed border-gray-200 dark:border-[#23332D] rounded-xl bg-gray-50 dark:bg-[#0F1714]/50">
                    <span class="material-symbols-outlined text-4xl text-gray-300 dark:text-[#313632] mb-3">play_circle</span>
                    <p class="text-gray-500 dark:text-[#A7B8B0] text-sm mb-4">No courses currently in progress.</p>
                    <a asp-controller="Discovery" asp-action="Index" class="inline-flex items-center gap-2 bg-white dark:bg-[#16211D] text-gray-800 dark:text-[#E6F1EC] border border-gray-200 dark:border-[#23332D] px-4 py-2 rounded-lg font-bold text-sm hover:bg-gray-50 dark:hover:bg-[#1B2A24] transition-colors shadow-sm">
                        <span class="material-symbols-outlined text-[18px]">explore</span> Explore Courses
                    </a>
                </div>
            }
        </div>

        <!-- Milestones -->
        @if (Model.Milestones?.Any() == true)
        {
            <div class="bg-white dark:bg-[#16211D] border border-gray-200 dark:border-[#23332D] rounded-2xl p-6 shadow-sm">
                <h2 class="font-serif font-bold text-xl text-gray-900 dark:text-[#E6F1EC] flex items-center gap-2 mb-4">
                    <span class="material-symbols-outlined text-amber-500">emoji_events</span>
                    Earned Milestones
                </h2>
                <div class="flex flex-wrap gap-2">
                    @foreach (var m in Model.Milestones)
                    {
                        <div class="flex items-center gap-1.5 bg-gradient-to-r from-amber-500 to-amber-600 text-white px-3 py-1.5 rounded-full text-xs font-bold shadow-sm">
                            <span class="material-symbols-outlined text-[14px]">star</span>
                            @m
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Right Column: Quick Actions + Recommendations -->
    <div class="space-y-8">
        
        <!-- Quick Actions -->
        <div class="bg-white dark:bg-[#16211D] border border-gray-200 dark:border-[#23332D] rounded-2xl p-6 shadow-sm">
            <h2 class="font-serif font-bold text-xl text-gray-900 dark:text-[#E6F1EC] flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-amber-500">bolt</span>
                Quick Actions
            </h2>
            <div class="space-y-3">
                <a asp-controller="Discovery" asp-action="Index" class="flex items-center gap-4 p-3 rounded-xl border border-transparent hover:border-gray-200 dark:hover:border-[#23332D] hover:bg-gray-50 dark:hover:bg-[#0F1714] transition-all group">
                    <div class="w-10 h-10 rounded-lg bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined">explore</span>
                    </div>
                    <div class="flex-1">
                        <div class="font-bold text-sm text-gray-900 dark:text-[#E6F1EC]">Discover Courses</div>
                        <div class="text-xs text-gray-500 dark:text-[#A7B8B0]">Browse & search catalog</div>
                    </div>
                    <span class="material-symbols-outlined text-gray-300 dark:text-[#313632] group-hover:text-primary transition-colors">chevron_right</span>
                </a>
                
                <a asp-controller="Discovery" asp-action="Books" class="flex items-center gap-4 p-3 rounded-xl border border-transparent hover:border-gray-200 dark:hover:border-[#23332D] hover:bg-gray-50 dark:hover:bg-[#0F1714] transition-all group">
                    <div class="w-10 h-10 rounded-lg bg-pink-100 dark:bg-pink-900/30 text-pink-600 dark:text-pink-400 flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined">menu_book</span>
                    </div>
                    <div class="flex-1">
                        <div class="font-bold text-sm text-gray-900 dark:text-[#E6F1EC]">Browse Books</div>
                        <div class="text-xs text-gray-500 dark:text-[#A7B8B0]">Open Library integration</div>
                    </div>
                    <span class="material-symbols-outlined text-gray-300 dark:text-[#313632] group-hover:text-primary transition-colors">chevron_right</span>
                </a>

                <a asp-controller="Bookmarks" asp-action="Index" class="flex items-center gap-4 p-3 rounded-xl border border-transparent hover:border-gray-200 dark:hover:border-[#23332D] hover:bg-gray-50 dark:hover:bg-[#0F1714] transition-all group">
                    <div class="w-10 h-10 rounded-lg bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined">bookmark</span>
                    </div>
                    <div class="flex-1">
                        <div class="font-bold text-sm text-gray-900 dark:text-[#E6F1EC]">My Bookmarks</div>
                        <div class="text-xs text-gray-500 dark:text-[#A7B8B0]">@Model.TotalBookmarks saved items</div>
                    </div>
                    <span class="material-symbols-outlined text-gray-300 dark:text-[#313632] group-hover:text-primary transition-colors">chevron_right</span>
                </a>
            </div>
        </div>

        <!-- Recommendations -->
        <div class="bg-white dark:bg-[#16211D] border border-gray-200 dark:border-[#23332D] rounded-2xl p-6 shadow-sm">
            <h2 class="font-serif font-bold text-xl text-gray-900 dark:text-[#E6F1EC] flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-blue-500">auto_awesome</span>
                Recommended
            </h2>
            
            @if (Model.RecommendedCourseIds?.Any() == true)
            {
                <div class="flex flex-wrap gap-2 mb-5">
                    @foreach (var id in Model.RecommendedCourseIds.Take(6))
                    {
                        <a asp-controller="Discovery" asp-action="Index" class="flex items-center gap-1.5 bg-gray-50 dark:bg-[#0F1714] border border-gray-200 dark:border-[#23332D] hover:border-primary dark:hover:border-primary text-gray-700 dark:text-[#A7B8B0] hover:text-primary dark:hover:text-primary px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">
                            <span class="material-symbols-outlined text-[14px]">play_circle</span>
                            Course #@id
                        </a>
                    }
                </div>
                <a asp-controller="Discovery" asp-action="Index" class="w-full flex items-center justify-center gap-2 py-2.5 rounded-xl border-2 border-gray-200 dark:border-[#23332D] text-gray-600 dark:text-[#A7B8B0] font-bold text-sm hover:border-primary hover:text-primary dark:hover:border-primary dark:hover:text-primary transition-colors">
                    See All Courses <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                </a>
            }
            else
            {
                <div class="text-center py-8 px-4">
                    <span class="material-symbols-outlined text-4xl text-gray-300 dark:text-[#313632] mb-2">auto_awesome</span>
                    <p class="text-gray-500 dark:text-[#A7B8B0] text-xs">Complete courses to unlock personalized picks.</p>
                </div>
            }
        </div>

    </div>
</div>

@section Scripts {
<script>
    // Update hero name from sessionStorage
    const storedName = sessionStorage.getItem('lh-name');
    if (storedName) {
        const el = document.getElementById('hero-name');
        if (el) el.textContent = storedName;
    }
</script>
}

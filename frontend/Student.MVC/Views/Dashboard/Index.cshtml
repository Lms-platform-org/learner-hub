@using LearningPlatform.StudentService.WebApp.Models.DTOs
@model LearningPlatform.StudentService.WebApp.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var name = Context.Session.GetString("name") ?? "Student";
}

<style>
    .dash-hero { margin-bottom: 2rem; }
    .dash-hero h1 { font-size: 2rem; font-weight: 800; margin-bottom: 0.3rem; }
    .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap: 1.2rem; margin-bottom: 2rem; }
    .xp-bar-wrap { background: rgba(99,102,241,0.1); border-radius: 16px; padding: 1.25rem 1.5rem; margin-bottom: 2rem; display: flex; align-items: center; gap: 1.5rem; }
    .xp-icon { width: 56px; height: 56px; background: linear-gradient(135deg,#f59e0b,#d97706); border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.6rem; color: white; flex-shrink: 0; }
    .xp-details { flex: 1; }
    .xp-number { font-size: 1.8rem; font-weight: 800; color: #f59e0b; }
    .xp-label { font-size: 0.82rem; color: var(--muted); margin-top: 2px; }
    .xp-next { font-size: 0.78rem; color: var(--muted); margin-top: 4px; }
    .cw-card {
        border-radius: 14px; padding: 1.1rem 1.3rem;
        background: var(--card-bg); border: 1px solid var(--border);
        display: flex; align-items: center; gap: 1rem;
        transition: all 0.2s; margin-bottom: 0.9rem;
        text-decoration: none; color: inherit;
    }
    body.dark .cw-card { background: var(--card-bg-dark); border-color: var(--border-dark); }
    .cw-card:hover { border-color: var(--primary); transform: translateX(4px); text-decoration: none; color: inherit; }
    .cw-icon { width: 46px; height: 46px; border-radius: 12px; background: linear-gradient(135deg,var(--primary),var(--secondary)); display: flex; align-items: center; justify-content: center; color: white; font-size: 1.1rem; flex-shrink: 0; }
    .cw-info { flex: 1; min-width: 0; }
    .cw-title { font-weight: 700; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cw-meta { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }
    .cw-pct { font-weight: 800; font-size: 1rem; color: var(--primary); flex-shrink: 0; }
    .rec-chip {
        display: inline-flex; align-items: center; gap: 0.4rem;
        padding: 0.5rem 1rem; border-radius: 12px;
        border: 2px solid var(--border); font-weight: 600; font-size: 0.85rem;
        cursor: pointer; transition: all 0.2s; text-decoration: none; color: inherit;
        background: var(--card-bg);
    }
    body.dark .rec-chip { background: var(--card-bg-dark); border-color: var(--border-dark); }
    .rec-chip:hover { border-color: var(--primary); color: var(--primary); transform: translateY(-2px); text-decoration: none; }
    .empty-state { text-align: center; padding: 3rem 1rem; color: var(--muted); }
    .empty-state i { font-size: 3rem; opacity: 0.35; display: block; margin-bottom: 1rem; }
    .section-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 1.5rem; margin-bottom: 1.5rem; }
    body.dark .section-card { background: var(--card-bg-dark); border-color: var(--border-dark); }
    .milestone-badge { display: inline-flex; align-items: center; gap: 0.3rem; background: linear-gradient(135deg,#f59e0b,#d97706); color: white; padding: 0.3rem 0.8rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; margin: 0.2rem; }
</style>

<!-- Hero -->
<div class="dash-hero fade-up">
    <h1>Good morning, <span class="text-gradient" id="hero-name">@name</span> 👋</h1>
    <p style="color:var(--muted); font-size:0.95rem;">Here's your learning overview for today</p>
</div>

<!-- XP Bar -->
@if (Model.TotalXP > 0)
{
<div class="xp-bar-wrap fade-up">
    <div class="xp-icon"><i class="bi bi-lightning-fill"></i></div>
    <div class="xp-details">
        <div class="xp-number" id="xp-number">@Model.TotalXP <span style="font-size:1rem; font-weight:600;">XP</span></div>
        <div class="xp-label">Total Experience Points earned</div>
        <div class="xp-next">
            @{
                var level = Model.TotalXP < 500 ? "Beginner" : Model.TotalXP < 1500 ? "Intermediate" : "Advanced";
                var nextXp = Model.TotalXP < 500 ? 500 : Model.TotalXP < 1500 ? 1500 : 5000;
                var pct = Math.Min((int)((double)Model.TotalXP / nextXp * 100), 100);
            }
            Level: <strong>@level</strong> · @(nextXp - Model.TotalXP) XP to next level
        </div>
    </div>
    <div style="width:140px; flex-shrink:0;">
        <div style="font-size:0.75rem; color:var(--muted); margin-bottom:4px; text-align:right;">@pct%</div>
        <div class="lh-progress"><div class="lh-progress-bar" data-pct="@pct" style="width:0"></div></div>
    </div>
</div>
}

<!-- Stats -->
@if (Model.EnrolledCount > 0 || Model.CompletedCount > 0 || Model.InProgressCount > 0 || Model.TotalBookmarks > 0)
{
<div class="stat-grid">
    <div class="stat-card" style="border-left-color:#6366f1;">
        <div class="stat-icon" style="background:rgba(99,102,241,0.12); color:#6366f1;"><i class="bi bi-journal-check"></i></div>
        <div>
            <div class="stat-number" style="color:#6366f1;">@Model.EnrolledCount</div>
            <div class="stat-label">Courses Enrolled</div>
        </div>
    </div>
    <div class="stat-card" style="border-left-color:#10b981;">
        <div class="stat-icon" style="background:rgba(16,185,129,0.12); color:#10b981;"><i class="bi bi-patch-check-fill"></i></div>
        <div>
            <div class="stat-number" style="color:#10b981;">@Model.CompletedCount</div>
            <div class="stat-label">Completed</div>
        </div>
    </div>
    <div class="stat-card" style="border-left-color:#f59e0b;">
        <div class="stat-icon" style="background:rgba(245,158,11,0.12); color:#f59e0b;"><i class="bi bi-play-circle-fill"></i></div>
        <div>
            <div class="stat-number" style="color:#f59e0b;">@Model.InProgressCount</div>
            <div class="stat-label">In Progress</div>
        </div>
    </div>
    <div class="stat-card" style="border-left-color:#ec4899;">
        <div class="stat-icon" style="background:rgba(236,72,153,0.12); color:#ec4899;"><i class="bi bi-bookmark-fill"></i></div>
        <div>
            <div class="stat-number" style="color:#ec4899;">@Model.TotalBookmarks</div>
            <div class="stat-label">Bookmarks</div>
        </div>
    </div>
</div>
}

<div class="row g-4">
    <!-- Left: Continue Watching -->
    <div class="col-lg-7">
        <div class="section-card">
            <div class="section-title">
                <i class="bi bi-play-circle-fill" style="color:var(--primary);"></i>
                Continue Watching
                @if (Model.ContinueWatching?.Any() == true)
                {
                    <span class="lh-badge lh-badge-primary ms-auto">@Model.ContinueWatching.Count courses</span>
                }
            </div>

            @if (Model.ContinueWatching?.Any() == true)
            {
                @foreach (var p in Model.ContinueWatching)
                {
                    <a href="/Enrollment/MyCourses" class="cw-card">
                        <div class="cw-icon"><i class="bi bi-play-fill"></i></div>
                        <div class="cw-info">
                            <div class="cw-title">Course #@p.LastLessonId</div>
                            <div class="cw-meta">
                                <span class="lh-badge lh-badge-warning me-1">In Progress</span>
                                Lesson @p.LastLessonId · @(TimeSpan.FromSeconds(p.LastVideoTimestampSeconds).ToString(@"mm\:ss")) resume point
                            </div>
                            <div class="lh-progress mt-2" style="height:5px;">
                                <div class="lh-progress-bar" data-pct="@p.Percentage" style="width:0;"></div>
                            </div>
                        </div>
                        <div class="cw-pct">@p.Percentage%</div>
                    </a>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-play-circle"></i>
                    <p>No courses in progress.</p>
                    <a asp-controller="Discovery" asp-action="Index" class="btn-lh btn-lh-primary mt-2">
                        <i class="bi bi-compass-fill"></i> Explore Courses
                    </a>
                </div>
            }
        </div>

        <!-- Milestones -->
        @if (Model.Milestones?.Any() == true)
        {
            <div class="section-card">
                <div class="section-title"><i class="bi bi-trophy-fill" style="color:#f59e0b;"></i> Earned Milestones</div>
                <div>
                    @foreach (var m in Model.Milestones)
                    {
                        <span class="milestone-badge"><i class="bi bi-star-fill"></i> @m</span>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Right: Quick Actions + Recommendations -->
    <div class="col-lg-5">
        <!-- Quick Actions -->
        <div class="section-card" style="margin-bottom:1.5rem;">
            <div class="section-title"><i class="bi bi-lightning-fill" style="color:var(--warning);"></i> Quick Actions</div>
            <div class="d-flex flex-column gap-2">
                <a asp-controller="Discovery" asp-action="Index" class="cw-card" style="margin-bottom:0;">
                    <div class="cw-icon" style="background:linear-gradient(135deg,#10b981,#059669);"><i class="bi bi-compass-fill"></i></div>
                    <div class="cw-info">
                        <div class="cw-title">Discover Courses</div>
                        <div class="cw-meta">Browse &amp; search courses</div>
                    </div>
                    <i class="bi bi-chevron-right" style="color:var(--muted);"></i>
                </a>
                <a asp-controller="Discovery" asp-action="Books" class="cw-card" style="margin-bottom:0;">
                    <div class="cw-icon" style="background:linear-gradient(135deg,#ec4899,#db2777);"><i class="bi bi-book-fill"></i></div>
                    <div class="cw-info">
                        <div class="cw-title">Browse Books</div>
                        <div class="cw-meta">Open Library integration</div>
                    </div>
                    <i class="bi bi-chevron-right" style="color:var(--muted);"></i>
                </a>
                <a asp-controller="Bookmarks" asp-action="Index" class="cw-card" style="margin-bottom:0;">
                    <div class="cw-icon" style="background:linear-gradient(135deg,#8b5cf6,#7c3aed);"><i class="bi bi-bookmark-fill"></i></div>
                    <div class="cw-info">
                        <div class="cw-title">My Bookmarks</div>
                        <div class="cw-meta">@Model.TotalBookmarks saved items</div>
                    </div>
                    <i class="bi bi-chevron-right" style="color:var(--muted);"></i>
                </a>
            </div>
        </div>

        <!-- Recommendations -->
        <div class="section-card">
            <div class="section-title"><i class="bi bi-stars" style="color:var(--secondary);"></i> Recommended For You</div>
            @if (Model.RecommendedCourseIds?.Any() == true)
            {
                <div style="display:flex; flex-wrap:wrap; gap:0.6rem;">
                    @foreach (var id in Model.RecommendedCourseIds.Take(6))
                    {
                        <a asp-controller="Discovery" asp-action="Index" class="rec-chip">
                            <i class="bi bi-play-circle-fill" style="color:var(--primary);"></i>
                            Course #@id
                        </a>
                    }
                </div>
                <div class="mt-3">
                    <a asp-controller="Discovery" asp-action="Index" class="btn-lh btn-lh-outline" style="width:100%; justify-content:center;">
                        <i class="bi bi-arrow-right"></i> See All Courses
                    </a>
                </div>
            }
            else
            {
                <div class="empty-state" style="padding:1.5rem 0;">
                    <i class="bi bi-stars" style="font-size:2rem; opacity:0.3;"></i>
                    <p style="font-size:0.85rem;">Complete courses to unlock personalized picks.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Update hero name from sessionStorage
    const storedName = sessionStorage.getItem('lh-name');
    if (storedName) {
        const el = document.getElementById('hero-name');
        if (el) el.textContent = storedName;
    }
</script>
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LearnHub</title>
    <meta name="description" content="LearnHub - Your personal learning dashboard for courses and books." />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --secondary: #8b5cf6;
            --accent: #ec4899;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --bg: #f8fafc;
            --bg-dark: #0f172a;
            --card-bg: #ffffff;
            --card-bg-dark: #1e293b;
            --text: #1e293b;
            --text-dark: #f1f5f9;
            --muted: #64748b;
            --border: #e2e8f0;
            --border-dark: #334155;
            --nav-height: 70px;
        }
        * { font-family: 'Inter', sans-serif; box-sizing: border-box; margin: 0; padding: 0; }
        h1,h2,h3,h4,h5,h6 { font-family: 'Poppins', sans-serif; font-weight: 700; }

        body {
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            transition: background 0.3s, color 0.3s;
        }
        body.dark {
            background: var(--bg-dark);
            color: var(--text-dark);
        }

        /* ── NAVBAR ── */
        .navbar {
            height: var(--nav-height);
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            box-shadow: 0 1px 20px rgba(0,0,0,0.06);
            position: sticky;
            top: 0;
            z-index: 1000;
            transition: background 0.3s, border-color 0.3s;
        }
        body.dark .navbar {
            background: rgba(15,23,42,0.90);
            border-bottom-color: var(--border-dark);
        }
        .navbar-brand {
            font-family: 'Poppins', sans-serif;
            font-weight: 800;
            font-size: 1.4rem;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-decoration: none;
        }
        .nav-link {
            color: var(--muted) !important;
            font-weight: 500;
            font-size: 0.9rem;
            padding: 0.5rem 0.9rem !important;
            border-radius: 8px;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }
        .nav-link:hover, .nav-link.active {
            color: var(--primary) !important;
            background: rgba(99,102,241,0.08);
        }
        body.dark .nav-link { color: #94a3b8 !important; }
        body.dark .nav-link:hover, body.dark .nav-link.active {
            color: #a5b4fc !important;
            background: rgba(99,102,241,0.15);
        }
        .icon-btn {
            width: 38px; height: 38px;
            border-radius: 10px;
            border: none;
            background: rgba(99,102,241,0.08);
            color: var(--primary);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 1rem;
        }
        .icon-btn:hover { background: rgba(99,102,241,0.18); transform: scale(1.08); }
        body.dark .icon-btn { background: rgba(99,102,241,0.15); color: #a5b4fc; }

        /* ── CARDS ── */
        .lh-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.05);
            transition: all 0.25s;
        }
        body.dark .lh-card {
            background: var(--card-bg-dark);
            border-color: var(--border-dark);
            box-shadow: 0 2px 12px rgba(0,0,0,0.25);
        }
        .lh-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.10);
        }
        body.dark .lh-card:hover { box-shadow: 0 8px 30px rgba(0,0,0,0.40); }

        /* ── BUTTONS ── */
        .btn-lh {
            display: inline-flex; align-items: center; gap: 0.45rem;
            padding: 0.55rem 1.3rem;
            border-radius: 10px;
            border: none;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
        }
        .btn-lh:hover { transform: translateY(-2px); }
        .btn-lh-primary { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: #fff; }
        .btn-lh-primary:hover { box-shadow: 0 6px 20px rgba(99,102,241,0.4); color: #fff; }
        .btn-lh-secondary { background: linear-gradient(135deg, var(--secondary), #7c3aed); color: #fff; }
        .btn-lh-success { background: linear-gradient(135deg, var(--success), #059669); color: #fff; }
        .btn-lh-danger { background: linear-gradient(135deg, var(--danger), #dc2626); color: #fff; }
        .btn-lh-outline {
            background: transparent;
            border: 2px solid var(--border);
            color: var(--muted);
        }
        .btn-lh-outline:hover { border-color: var(--primary); color: var(--primary); }
        body.dark .btn-lh-outline { border-color: var(--border-dark); color: #94a3b8; }

        /* ── BADGES ── */
        .lh-badge {
            display: inline-flex; align-items: center; gap: 0.25rem;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .lh-badge-primary { background: rgba(99,102,241,0.12); color: var(--primary); }
        .lh-badge-success { background: rgba(16,185,129,0.12); color: var(--success); }
        .lh-badge-warning { background: rgba(245,158,11,0.12); color: var(--warning); }
        .lh-badge-danger { background: rgba(239,68,68,0.12); color: var(--danger); }
        .lh-badge-purple { background: rgba(139,92,246,0.12); color: var(--secondary); }
        .lh-badge-pink { background: rgba(236,72,153,0.12); color: var(--accent); }
        body.dark .lh-badge-primary { background: rgba(99,102,241,0.2); }
        body.dark .lh-badge-success { background: rgba(16,185,129,0.2); }

        /* ── PROGRESS ── */
        .lh-progress { height: 8px; border-radius: 99px; background: var(--border); overflow: hidden; }
        body.dark .lh-progress { background: var(--border-dark); }
        .lh-progress-bar {
            height: 100%; border-radius: 99px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            transition: width 0.8s cubic-bezier(0.34,1.56,0.64,1);
        }

        /* ── FORMS ── */
        .lh-input {
            width: 100%;
            padding: 0.65rem 1rem;
            border-radius: 10px;
            border: 2px solid var(--border);
            background: var(--card-bg);
            color: var(--text);
            font-size: 0.95rem;
            transition: all 0.2s;
            outline: none;
        }
        .lh-input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(99,102,241,0.12); }
        body.dark .lh-input { background: #1e293b; border-color: var(--border-dark); color: var(--text-dark); }
        body.dark .lh-input:focus { border-color: #818cf8; }

        /* ── STAT BOXES ── */
        .stat-card {
            padding: 1.5rem;
            border-radius: 16px;
            border-left: 4px solid;
            display: flex; align-items: center; gap: 1.2rem;
            background: var(--card-bg);
            border-top: 1px solid var(--border);
            border-right: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            box-shadow: 0 2px 12px rgba(0,0,0,0.05);
            transition: all 0.25s;
        }
        body.dark .stat-card { background: var(--card-bg-dark); border-top-color: var(--border-dark); border-right-color: var(--border-dark); border-bottom-color: var(--border-dark); }
        .stat-card:hover { transform: translateY(-3px); box-shadow: 0 8px 25px rgba(0,0,0,0.10); }
        .stat-icon {
            width: 52px; height: 52px; border-radius: 13px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; flex-shrink: 0;
        }
        .stat-number { font-size: 2rem; font-weight: 800; line-height: 1; }
        .stat-label { font-size: 0.82rem; color: var(--muted); font-weight: 500; margin-top: 2px; }

        /* ── TOASTS ── */
        #toast-container {
            position: fixed; top: 80px; right: 20px; z-index: 9999;
            display: flex; flex-direction: column; gap: 10px;
            pointer-events: none;
        }
        .lh-toast {
            display: flex; align-items: center; gap: 10px;
            padding: 0.85rem 1.2rem;
            border-radius: 12px;
            font-weight: 600; font-size: 0.9rem;
            color: white;
            pointer-events: all;
            animation: toastIn 0.35s cubic-bezier(0.34,1.56,0.64,1) forwards;
            box-shadow: 0 8px 25px rgba(0,0,0,0.2);
            max-width: 320px;
        }
        .lh-toast.out { animation: toastOut 0.3s ease forwards; }
        .lh-toast-success { background: linear-gradient(135deg, #10b981, #059669); }
        .lh-toast-error   { background: linear-gradient(135deg, #ef4444, #dc2626); }
        .lh-toast-info    { background: linear-gradient(135deg, #6366f1, #4f46e5); }
        .lh-toast-warning { background: linear-gradient(135deg, #f59e0b, #d97706); }
        @@keyframes toastIn { from { opacity:0; transform: translateX(60px) scale(0.9); } to { opacity:1; transform: translateX(0) scale(1); } }
        @@keyframes toastOut { from { opacity:1; transform: translateX(0); } to { opacity:0; transform: translateX(60px); } }

        /* ── ANIMATIONS ── */
        @@keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
        @@keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.5; } }
        .fade-up { animation: fadeUp 0.5s ease forwards; }
        .skeleton { background: linear-gradient(90deg, var(--border) 25%, #f1f5f9 50%, var(--border) 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 8px; }
        body.dark .skeleton { background: linear-gradient(90deg, var(--border-dark) 25%, #334155 50%, var(--border-dark) 75%); background-size: 200% 100%; }
        @@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

        /* ── MISC ── */
        .text-gradient { background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .section-title { font-size: 1.3rem; font-weight: 700; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; }
        .divider { height: 1px; background: var(--border); margin: 1.5rem 0; }
        body.dark .divider { background: var(--border-dark); }
        .page-wrapper { padding: 2rem 0 4rem; }

        /* ── DARK DROPDOWN ── */
        body.dark .dropdown-menu { background: #1e293b; border-color: var(--border-dark); }
        body.dark .dropdown-item { color: #cbd5e1; }
        body.dark .dropdown-item:hover { background: #334155; color: #f1f5f9; }

        /* ── ALERTS ── */
        .lh-alert { padding: 0.9rem 1.2rem; border-radius: 10px; border-left: 4px solid; display: flex; align-items: center; gap: 0.6rem; font-weight: 500; margin-bottom: 1rem; }
        .lh-alert-success { background: rgba(16,185,129,0.08); border-left-color: var(--success); color: #065f46; }
        .lh-alert-error { background: rgba(239,68,68,0.08); border-left-color: var(--danger); color: #7f1d1d; }
        body.dark .lh-alert-success { background: rgba(16,185,129,0.15); color: #86efac; }
        body.dark .lh-alert-error { background: rgba(239,68,68,0.15); color: #fca5a5; }

        /* ── RESPONSIVE ── */
        @@media (max-width: 768px) { .page-wrapper { padding: 1.25rem 0 3rem; } }

        /* ── FOOTER ── */
        footer {
            background: linear-gradient(135deg, #1e293b, #0f172a);
            color: #94a3b8; padding: 2.5rem 0 1.5rem; margin-top: 4rem;
        }
        footer a { color: #818cf8; text-decoration: none; transition: color 0.2s; }
        footer a:hover { color: #a5b4fc; }
    </style>
</head>
<body>
    <!-- Toast Container -->
    <div id="toast-container"></div>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="/Dashboard">
                <i class="bi bi-mortarboard-fill"></i> LearnHub
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                           asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Enrollment" ? "active" : "")"
                           asp-controller="Enrollment" asp-action="MyCourses">
                            <i class="bi bi-journal-check"></i> My Courses
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Discovery" ? "active" : "")"
                           asp-controller="Discovery" asp-action="Index">
                            <i class="bi bi-compass-fill"></i> Discover
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Bookmarks" ? "active" : "")"
                           asp-controller="Bookmarks" asp-action="Index">
                            <i class="bi bi-bookmark-fill"></i> Bookmarks
                            <span id="nav-bookmark-badge" style="display:none;" class="lh-badge lh-badge-primary ms-1" id="bm-count"></span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Profile" ? "active" : "")"
                           asp-controller="Profile" asp-action="Index">
                            <i class="bi bi-person-circle"></i> Profile
                        </a>
                    </li>
                </ul>
                <div class="ms-3 d-flex align-items-center gap-2">
                    <button class="icon-btn" id="darkToggle" title="Toggle dark mode" onclick="toggleDark()">
                        <i class="bi bi-moon-fill" id="darkIcon"></i>
                    </button>
                    <div class="dropdown">
                        <button class="icon-btn" data-bs-toggle="dropdown">
                            <i class="bi bi-person-fill"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow" style="border-radius:12px; min-width:180px;">
                            <li>
                                <div class="px-3 py-2">
                                    <div style="font-weight:700; font-size:0.9rem;" id="nav-user-name">Student</div>
                                    <div style="font-size:0.78rem; color:var(--muted);" id="nav-user-email"></div>
                                </div>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index"><i class="bi bi-person me-2"></i>Profile</a></li>
                            <li><a class="dropdown-item text-danger" asp-controller="Login" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Alerts from TempData -->
    <div class="container-fluid px-4 mt-3" id="tempdata-alerts">
        @if (TempData["Success"] != null)
        {
            <div class="lh-alert lh-alert-success fade-up">
                <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                <button class="btn-close ms-auto btn-sm" onclick="this.parentElement.remove()"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="lh-alert lh-alert-error fade-up">
                <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
                <button class="btn-close ms-auto btn-sm" onclick="this.parentElement.remove()"></button>
            </div>
        }
    </div>

    <!-- Main -->
    <main class="page-wrapper">
        <div class="container-fluid px-4">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer>
        <div class="container-fluid px-4">
            <div class="row mb-3">
                <div class="col-md-4 mb-3">
                    <h6 style="font-family:'Poppins',sans-serif; color:#f1f5f9; font-weight:700;">
                        <i class="bi bi-mortarboard-fill"></i> LearnHub
                    </h6>
                    <p style="font-size:0.82rem;">Empowering students with world-class learning experiences.</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h6 style="color:#f1f5f9; font-size:0.85rem;">Quick Links</h6>
                    <div class="d-flex gap-3 flex-wrap" style="font-size:0.82rem;">
                        <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                        <a asp-controller="Discovery" asp-action="Index">Discover</a>
                        <a asp-controller="Bookmarks" asp-action="Index">Bookmarks</a>
                        <a asp-controller="Profile" asp-action="Index">Profile</a>
                    </div>
                </div>
                <div class="col-md-4 mb-3 text-md-end">
                    <a href="#" class="me-3 fs-5"><i class="bi bi-github"></i></a>
                    <a href="#" class="me-3 fs-5"><i class="bi bi-linkedin"></i></a>
                    <a href="#" class="fs-5"><i class="bi bi-twitter"></i></a>
                </div>
            </div>
            <hr style="border-color:#334155;">
            <div style="font-size:0.8rem; text-align:center;">&copy; 2026 LearnHub. All rights reserved.</div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ── DARK MODE ──
        function toggleDark() {
            const on = document.body.classList.toggle('dark');
            localStorage.setItem('lh-dark', on);
            document.getElementById('darkIcon').className = on ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
        }
        (function () {
            if (localStorage.getItem('lh-dark') === 'true') {
                document.body.classList.add('dark');
                const icon = document.getElementById('darkIcon');
                if (icon) icon.className = 'bi bi-sun-fill';
            }
        })();

        // ── SESSION INFO ──
        (function () {
            const name = sessionStorage.getItem('lh-name') || '';
            const email = sessionStorage.getItem('lh-email') || '';
            const n = document.getElementById('nav-user-name');
            const e = document.getElementById('nav-user-email');
            if (n && name) n.textContent = name;
            if (e && email) e.textContent = email;
        })();

        // ── TOAST SYSTEM ──
        function showToast(message, type = 'info', duration = 3500) {
            const container = document.getElementById('toast-container');
            const id = 'toast-' + Date.now();
            const icons = { success: 'bi-check-circle-fill', error: 'bi-exclamation-circle-fill', info: 'bi-info-circle-fill', warning: 'bi-exclamation-triangle-fill' };
            const div = document.createElement('div');
            div.id = id;
            div.className = `lh-toast lh-toast-${type}`;
            div.innerHTML = `<i class="bi ${icons[type] || icons.info}"></i><span>${message}</span><button onclick="dismissToast('${id}')" style="background:none;border:none;color:rgba(255,255,255,0.8);margin-left:auto;cursor:pointer;font-size:1rem;"><i class="bi bi-x-lg"></i></button>`;
            container.appendChild(div);
            setTimeout(() => dismissToast(id), duration);
        }
        function dismissToast(id) {
            const el = document.getElementById(id);
            if (!el) return;
            el.classList.add('out');
            setTimeout(() => el?.remove(), 300);
        }

        // ── GLOBAL BOOKMARK STATE ──
        const BookmarkState = {
            set: new Set(),
            count: 0,
            async load() {
                try {
                    const r = await fetch('/Bookmarks/GetAllAjax', { headers: this._headers() });
                    if (!r.ok) return;
                    const json = await r.json();
                    const items = json?.data ?? [];
                    this.set.clear();
                    items.forEach(b => {
                        if (b.courseId) this.set.add('course-' + b.courseId);
                        if (b.bookKey) this.set.add('book-' + b.bookKey);
                    });
                    this.count = json?.totalCount ?? items.length;
                    this._updateUI();
                } catch (e) { console.warn('Bookmark load skipped', e); }
            },
            _headers() {
                const jwt = sessionStorage.getItem('lh-jwt') || '';
                return jwt ? { 'Authorization': 'Bearer ' + jwt } : {};
            },
            has(type, id) { return this.set.has(type + '-' + id); },
            add(type, id) { this.set.add(type + '-' + id); this.count++; this._updateUI(); },
            remove(type, id) { this.set.delete(type + '-' + id); this.count = Math.max(0, this.count - 1); this._updateUI(); },
            _updateUI() {
                const badge = document.getElementById('nav-bookmark-badge');
                if (badge) {
                    badge.textContent = this.count;
                    badge.style.display = this.count > 0 ? '' : 'none';
                }
                document.querySelectorAll('[data-bm-btn]').forEach(btn => {
                    const type = btn.dataset.bmType;
                    const id = btn.dataset.bmId;
                    const bookmarked = this.has(type, id);
                    btn.classList.toggle('bookmarked', bookmarked);
                    const icon = btn.querySelector('i');
                    if (icon) icon.className = bookmarked ? 'bi bi-bookmark-fill' : 'bi bi-bookmark';
                    const txt = btn.querySelector('.bm-text');
                    if (txt) txt.textContent = bookmarked ? 'Saved' : 'Save';
                });
            }
        };

        document.addEventListener('DOMContentLoaded', () => { BookmarkState.load(); });

        // ── PROGRESS BARS ANIMATE ──
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.lh-progress-bar[data-pct]').forEach(bar => {
                setTimeout(() => { bar.style.width = bar.dataset.pct + '%'; }, 200);
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

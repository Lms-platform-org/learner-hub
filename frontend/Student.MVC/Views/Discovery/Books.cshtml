@using LearningPlatform.StudentService.WebApp.Models.DTOs
@model PagedResponseDto<BookDto>
@{
    ViewData["Title"] = "Discover Books";
    var topic = ViewBag.Topic as string ?? "";
    var totalPages = Model.TotalCount > 0 ? (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize) : 1;
    var currentPage = Model.Page;
}

<style>
    .book-hero { margin-bottom: 2rem; }
    .search-bar-wrap {
        display: flex; gap: 0.7rem; margin-bottom: 2rem;
        background: var(--card-bg); border: 2px solid var(--border);
        border-radius: 14px; padding: 0.5rem 0.7rem; transition: border-color 0.2s;
    }
    body.dark .search-bar-wrap { background: var(--card-bg-dark); border-color: var(--border-dark); }
    .search-bar-wrap:focus-within { border-color: var(--accent); }
    .search-bar-wrap input {
        flex: 1; border: none; outline: none; background: transparent;
        font-size: 1rem; color: var(--text); font-weight: 500;
    }
    body.dark .search-bar-wrap input { color: var(--text-dark); }
    .search-bar-wrap input::placeholder { color: var(--muted); }
    .book-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px,1fr)); gap: 1.3rem; }
    .book-card {
        border-radius: 16px; overflow: hidden;
        background: var(--card-bg); border: 1px solid var(--border);
        box-shadow: 0 2px 12px rgba(0,0,0,0.05); transition: all 0.25s;
        display: flex; flex-direction: column;
    }
    body.dark .book-card { background: var(--card-bg-dark); border-color: var(--border-dark); }
    .book-card:hover { transform: translateY(-5px); box-shadow: 0 14px 40px rgba(0,0,0,0.12); border-color: var(--accent); }
    .book-card:hover { transform: translateY(-5px); box-shadow: 0 14px 40px rgba(0,0,0,0.12); border-color: var(--accent); }
    .book-thumb {
        height: 180px; background: linear-gradient(135deg, var(--accent) 0%, var(--secondary) 100%);
        display: flex; align-items: center; justify-content: center;
        color: white; font-size: 3rem; position: relative; flex-shrink: 0;
    }
    .book-thumb img { width:100%; height:100%; object-fit:cover; opacity: 0.9; }
    .book-thumb-overlay { position:absolute; inset:0; background:rgba(0,0,0,0.4); display:flex; align-items:center; justify-content:center; opacity:0; transition:opacity 0.2s; }
    .book-card:hover .book-thumb-overlay { opacity:1; }
    .book-body { padding: 1.1rem; flex: 1; display: flex; flex-direction: column; }
    .book-title { font-weight: 700; font-size: 1.05rem; margin-bottom: 0.3rem; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .book-author { font-size: 0.85rem; color: var(--muted); margin-bottom: 0.8rem; display: flex; align-items: center; gap: 0.4rem; }
    .book-meta { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.8rem; }
    .book-footer { display: flex; gap: 0.5rem; margin-top: auto; }
    .book-footer .btn-lh { flex: 1; justify-content: center; font-size: 0.82rem; padding: 0.5rem 0.7rem; }
    .bm-btn { width: 38px; height: 38px; border-radius: 10px; border: 2px solid var(--border); background: transparent; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; color: var(--muted); flex-shrink: 0; }
    .bm-btn:hover, .bm-btn.bookmarked { border-color: #f59e0b; color: #f59e0b; background: rgba(245,158,11,0.08); }
    .bm-btn.bookmarked i { font-weight: 900; }
    body.dark .bm-btn { border-color: var(--border-dark); }
    .tabs { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; }
    .tab-btn { padding: 0.6rem 1.3rem; border-radius: 10px; border: 2px solid var(--border); background: transparent; font-weight: 600; font-size: 0.88rem; cursor: pointer; color: var(--muted); transition: all 0.2s; }
    .tab-btn { padding: 0.6rem 1.3rem; border-radius: 10px; border: 2px solid var(--border); background: transparent; font-weight: 600; font-size: 0.88rem; cursor: pointer; color: var(--muted); transition: all 0.2s; }
    .tab-btn.active, .tab-btn:hover { border-color: var(--accent); color: var(--accent); background: rgba(20,184,166,0.07); }
    body.dark .tab-btn { border-color: var(--border-dark); }
    .page-btn { width: 38px; height: 38px; border-radius: 10px; border: 2px solid var(--border); background: transparent; font-weight: 700; cursor: pointer; transition: all 0.2s; color: var(--text); display: flex; align-items: center; justify-content: center; }
    .page-btn:hover, .page-btn.active { border-color: var(--accent); color: var(--accent); background: rgba(20,184,166,0.08); }
    body.dark .page-btn { border-color: var(--border-dark); color: var(--text-dark); }
    .no-results { text-align:center; padding: 4rem 1rem; color: var(--muted); }
    .no-results i { font-size: 3rem; opacity: 0.3; display: block; margin-bottom: 1rem; }
</style>

<div class="book-hero fade-up">
    <h1>Library <span class="text-gradient" style="background: linear-gradient(135deg, var(--accent), var(--secondary)); -webkit-background-clip: text;">Books</span></h1>
    <p style="color:var(--muted);">Explore books via Open Library API</p>
</div>

<!-- Search Bar -->
<form method="get" asp-controller="Discovery" asp-action="Books" id="searchForm">
    <div class="search-bar-wrap fade-up">
        <i class="bi bi-search" style="color:var(--muted); font-size:1.1rem; align-self:center; padding:0 0.3rem;"></i>
        <input type="text" name="topic" id="searchInput" value="@topic" placeholder="Search books by title, author, or topic..." autocomplete="off" />
        <input type="text" name="topic" id="searchInput" value="@topic" placeholder="Search books by title, author, or topic..." autocomplete="off" />
        <button type="submit" class="btn-lh btn-lh-primary" style="padding:0.55rem 1.2rem;">
            <i class="bi bi-search"></i> Search
        </button>
        @if (!string.IsNullOrEmpty(topic))
        {
            <a asp-controller="Discovery" asp-action="Books" class="btn-lh btn-lh-outline">
                <i class="bi bi-x-lg"></i> Clear
            </a>
        }
    </div>
</form>

<!-- Tabs -->
<div class="tabs fade-up">
    <a asp-controller="Discovery" asp-action="Index" class="tab-btn"><i class="bi bi-play-circle-fill"></i> Courses</a>
    <button class="tab-btn active" id="tab-books"><i class="bi bi-book-fill"></i> Books (@Model.TotalCount)</button>
</div>

@if (!string.IsNullOrEmpty(topic))
{
    <div style="margin-bottom:1.2rem; font-size:0.9rem; color:var(--muted);">
        Showing results for: <strong style="color:var(--text);">"@topic"</strong>
        · @Model.TotalCount result(s)
    </div>
}
else if (Model.Data?.Any() != true)
{
    <div class="no-results fade-up">
        <i class="bi bi-search"></i>
        <p style="font-weight:700; font-size:1.1rem;">Search for books</p>
        <p style="font-size:0.88rem;">Type a topic above to explore millions of free books.</p>
        <div class="mt-3" style="display:flex; gap:0.5rem; justify-content:center; flex-wrap:wrap;">
            <a href="?topic=python" class="lh-badge lh-badge-primary cursor-pointer">#python</a>
            <a href="?topic=javascript" class="lh-badge lh-badge-primary cursor-pointer">#javascript</a>
            <a href="?topic=architecture" class="lh-badge lh-badge-primary cursor-pointer">#architecture</a>
        </div>
    </div>
}

<!-- Book Grid -->
@if (Model.Data?.Any() == true)
{
    <div class="book-grid fade-up" id="bookGrid">
        @foreach (var b in Model.Data)
        {
            <div class="book-card">
                <div class="book-thumb">
                    <i class="bi bi-book-half"></i>
                    <div class="book-thumb-overlay">
                        <a href="@($"https://openlibrary.org{b.Key}")" target="_blank" class="btn-lh" style="background:var(--card-bg); color:var(--text);">
                            <i class="bi bi-book-fill" style="color:var(--accent);"></i> Read Now
                        </a>
                    </div>
                </div>
                <div class="book-body">
                    <div class="book-meta">
                        <span class="lh-badge lh-badge-primary">Book</span>
                        @if (b.FirstPublishYear.HasValue)
                        {
                            <span class="lh-badge" style="background:rgba(100,116,139,0.1); color:var(--muted);">@b.FirstPublishYear.Value</span>
                        }
                    </div>
                    <div class="book-title" title="@b.Title">@b.Title</div>
                    <div class="book-author">
                        <i class="bi bi-pen-fill"></i> @b.Authors
                    </div>
                    
                    <div class="book-footer">
                        <a href="@($"https://openlibrary.org{b.Key}")" target="_blank"
                           class="btn-lh" style="background:linear-gradient(135deg,var(--accent),var(--secondary)); color:white;">
                            <i class="bi bi-box-arrow-up-right"></i> Details
                        </a>
                        <button class="bm-btn" data-bm-btn data-bm-type="book" data-bm-id="@b.Key"
                                onclick="toggleBookBm(this, '@b.Key', '@Uri.EscapeDataString(b.Title ?? "")', '@Uri.EscapeDataString(b.Authors)')"
                                title="Bookmark">
                            <i class="bi bi-bookmark"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="d-flex justify-content-center gap-2 mt-4 fade-up">
            @if (currentPage > 1)
            {
                <a href="?@(string.IsNullOrEmpty(topic) ? "" : $"topic={Uri.EscapeDataString(topic)}&")page=@(currentPage - 1)" class="page-btn"><i class="bi bi-chevron-left"></i></a>
            }
            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
            {
                <a href="?@(string.IsNullOrEmpty(topic) ? "" : $"topic={Uri.EscapeDataString(topic)}&")page=@i" class="page-btn @(i == currentPage ? "active" : "")">@i</a>
            }
            @if (currentPage < totalPages)
            {
                <a href="?@(string.IsNullOrEmpty(topic) ? "" : $"topic={Uri.EscapeDataString(topic)}&")page=@(currentPage + 1)" class="page-btn"><i class="bi bi-chevron-right"></i></a>
            }
        </div>
    }
}
else if (!string.IsNullOrEmpty(topic))
{
    <div class="no-results fade-up">
        <i class="bi bi-journal-x"></i>
        <p style="font-weight:700; font-size:1.1rem;">No books found</p>
        <p style="font-size:0.88rem;">Try searching with different keywords or authors.</p>
        <a asp-controller="Discovery" asp-action="Books" class="btn-lh btn-lh-outline mt-3">Clear Search</a>
    </div>
}

@section Scripts {
<script>
    async function toggleBookBm(btn, bookKey, encodedTitle, encodedAuthor) {
        btn.disabled = true;
        try {
            const r = await fetch('/Discovery/BookmarkAjax', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    bookKey: bookKey, 
                    bookTitle: decodeURIComponent(encodedTitle), 
                    bookAuthor: decodeURIComponent(encodedAuthor),
                    type: 'book' 
                })
            });
            const data = await r.json();
            if (data.isBookmarked) {
                BookmarkState.add('book', bookKey);
                showToast('Book added to library!', 'success');
            } else {
                BookmarkState.remove('book', bookKey);
                showToast('Book removed', 'info');
            }
        } catch {
            showToast('Could not update bookmark', 'error');
        } finally {
            btn.disabled = false;
        }
    }

    // Live search debounce
    let searchTimer;
    document.getElementById('searchInput').addEventListener('input', function () {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(() => {
            const q = this.value.trim();
            if (q.length > 2 || q.length === 0) document.getElementById('searchForm').submit();
        }, 800);
    });
</script>
}

@using LearningPlatform.StudentService.WebApp.Models.DTOs
@model PagedResponseDto<CourseDto>

@{
    ViewData["Title"] = "Discover Courses";
    var query = ViewBag.Query as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-compass-fill me-2 text-primary"></i>Discover Courses</h2>
    <a asp-action="Books" class="btn btn-outline-secondary">
        <i class="bi bi-book me-2"></i>Browse Books
    </a>
</div>

@* Search bar *@
<form asp-action="Search" method="get" class="mb-4">
    <div class="input-group">
        <input name="query" value="@query" class="form-control form-control-lg"
               placeholder="Search courses e.g. Python, Machine Learning, Web..." />
        <button class="btn btn-primary" type="submit">
            <i class="bi bi-search me-1"></i>Search
        </button>
        @if (!string.IsNullOrEmpty(query))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

@if (!string.IsNullOrEmpty(query))
{
    <p class="text-muted mb-3">Results for "<strong>@query</strong>"</p>
}

@if (Model?.Data == null || !Model.Data.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        @if (string.IsNullOrEmpty(query))
        {
            <span>No courses available yet — check back soon.</span>
        }
        else
        {
            <span>No courses found for "@query". Try a different search.</span>
        }
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var course in Model.Data)
        {
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-primary">@(course.Category ?? "General")</span>
                            <span class="badge bg-secondary">@(course.Level ?? "All Levels")</span>
                        </div>
                        <h5 class="card-title fw-bold">@course.Title</h5>
                        <p class="card-text text-muted small">
                            @(course.Description ?? "No description available.")
                        </p>
                        <p class="text-muted small">
                            <i class="bi bi-collection-play me-1"></i>@course.TotalLessons lessons
                        </p>
                    </div>
                    <div class="card-footer bg-white border-0 d-flex gap-2">
                        <form asp-action="Enroll" asp-controller="Enrollment"
                              asp-route-courseId="@course.Id" method="post" class="flex-grow-1">
                            <button class="btn btn-primary w-100">
                                <i class="bi bi-plus-circle me-1"></i>Enroll
                            </button>
                        </form>
                        <button class="btn btn-outline-warning"
                                data-bs-toggle="modal"
                                data-bs-target="#bookmarkModal"
                                data-courseid="@course.Id"
                                data-title="@course.Title"
                                title="Bookmark">
                            <i class="bi bi-bookmark-plus"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Pagination *@
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @if (Model.Page > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="?query=@query&page=@(Model.Page - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
            }
            <li class="page-item active"><span class="page-link">@Model.Page</span></li>
            @if (Model.Page * Model.PageSize < Model.TotalCount)
            {
                <li class="page-item">
                    <a class="page-link" href="?query=@query&page=@(Model.Page + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            }
        </ul>
    </nav>
}

@* Bookmark Modal *@
<div class="modal fade" id="bookmarkModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-bookmark-plus me-2 text-warning"></i>Bookmark Course
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Bookmark" method="post">
                <div class="modal-body">
                    <input type="hidden" name="courseId" id="modalCourseId" />
                    <p class="text-muted" id="modalCourseTitle"></p>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Category</label>
                        <select name="category" class="form-select">
                            <option value="general">General</option>
                            <option value="python">Python</option>
                            <option value="ml">Machine Learning</option>
                            <option value="web">Web Development</option>
                            <option value="database">Database</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Note <small class="text-muted">(optional)</small></label>
                        <textarea name="note" class="form-control" rows="2"
                                  placeholder="Why are you bookmarking this?"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-bookmark-check me-1"></i>Save Bookmark
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('bookmarkModal').addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            document.getElementById('modalCourseId').value = btn.getAttribute('data-courseid');
            document.getElementById('modalCourseTitle').textContent = btn.getAttribute('data-title');
        });
    </script>
}
